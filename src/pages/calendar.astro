---
export const prerender = true;

import Layout from '../layouts/Layout.astro';
import BackgroundBlobs from '../components/BackgroundBlobs.astro';
import TimelineRow from '../components/TimelineRow.astro';
import VisualCalendar from '../components/VisualCalendar.astro';
import { getAllCalendarMatches } from '../lib/db';
import type { CalendarMatch } from '../types';

const matches: CalendarMatch[] = await getAllCalendarMatches();

// Agrupar por fecha
const groupedMatches = matches.reduce((acc: Record<string, CalendarMatch[]>, match) => {
    if (!acc[match.date]) acc[match.date] = [];
    acc[match.date].push(match);
    return acc;
}, {});

const sortedDates = Object.keys(groupedMatches).sort();
---

<Layout title="Calendario | Mundial 2026">
    <div class="relative min-h-screen">
        <BackgroundBlobs />

        <div class="relative z-10 max-w-[1100px] mx-auto px-6 md:px-0 pt-16 md:pt-8 pb-4">
            <header class="">
                <div class="flex items-center gap-3">
                    <div class="w-12 h-1.5 bg-gold rounded-full"></div>
                    <h2 class="text-gold font-bold tracking-[6px] uppercase text-[0.7rem] md:text-sm">Calendario</h2>
                </div>
            </header>
        </div>

        <!-- Visual Calendar Ribbon Filter -->
        <VisualCalendar activeDates={sortedDates} />

        <div class="relative z-10 max-w-[1100px] mx-auto px-0 pb-16 md:pb-8">
            <!-- Timeline Container -->
            <div class="relative flex flex-col gap-24" id="timeline-container">
                <!-- No Results Message -->
                <div id="no-results-message" class="hidden flex-col items-center justify-center py-20 text-center animate-fade-in">
                    <div class="w-16 h-16 rounded-full bg-white/5 flex items-center justify-center mb-6 text-white/30 border border-white/10">
                        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                    </div>
                    <h3 class="font-bebas text-3xl md:text-4xl text-white tracking-widest mb-2">No hay partidos</h3>
                    <p class="text-white/50 text-sm max-w-sm px-6">Ningún partido coincide con los filtros de fecha, grupo y equipo.</p>
                </div>

                {sortedDates.map((date, index) => (
                    <div class="timeline-day-group transition-all duration-500 ease-in-out" data-date={date}>
                        <TimelineRow 
                            date={date as string} 
                            dayMatches={groupedMatches[date as string]} 
                            index={index} 
                            isLast={index === sortedDates.length - 1} 
                        />
                    </div>
                ))}
            </div>
        </div>
    </div>
</Layout>
