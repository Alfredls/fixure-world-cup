---
import Layout from '../layouts/Layout.astro';
import BackgroundBlobs from '../components/BackgroundBlobs.astro';
import TimelineRow from '../components/TimelineRow.astro';
import VisualCalendar from '../components/VisualCalendar.astro';
import { supabase } from '../lib/supabase';
import { formatMatchTime } from '../lib/dateUtils';

// Intentar obtener datos de Supabase
let matches = [];
const { data: matchesData, error } = await supabase
    .from('matches')
    .select(`
        id,
        match_date,
        match_time,
        status,
        phase,
        group_id,
        home_team:teams!home_team_id(name, flag_emoji),
        away_team:teams!away_team_id(name, flag_emoji),
        venue:venues(name, city)
    `)
    .order('match_date', { ascending: true })
    .order('match_time', { ascending: true });

if (!error && matchesData && matchesData.length > 0) {
    matches = matchesData.map(m => {
        const home = Array.isArray(m.home_team) ? m.home_team[0] : m.home_team;
        const away = Array.isArray(m.away_team) ? m.away_team[0] : m.away_team;
        const venueInfo = Array.isArray(m.venue) ? m.venue[0] : m.venue;
        
        return {
            id: m.id,
            homeTeam: { name: home?.name || 'TBD', flag: home?.flag_emoji || 'unk.png' },
            awayTeam: { name: away?.name || 'TBD', flag: away?.flag_emoji || 'unk.png' },
            date: m.match_date,
            time: formatMatchTime(m.match_time),
            venue: venueInfo?.name || 'TBD',
            city: venueInfo?.city || '',
            phase: m.phase,
            group: m.group_id ? `Grupo ${m.group_id}` : '',
            status: m.status
        };
    });
} else {
    // Datos de prueba si no hay en DB
    matches = [
        { id: 1, homeTeam: { name: 'México', flag: 'mex.png' }, awayTeam: { name: 'Sudáfrica', flag: 'rsa.png' }, date: '2026-06-11', time: '15:00 Hrs.', venue: 'Estadio Azteca', city: 'Ciudad de México', phase: 'group', group: 'Grupo A', status: 'scheduled' },
        { id: 2, homeTeam: { name: 'Canadá', flag: 'can.png' }, awayTeam: { name: 'Suiza', flag: 'sui.png' }, date: '2026-06-12', time: '15:00 Hrs.', venue: 'BMO Field', city: 'Toronto', phase: 'group', group: 'Grupo B', status: 'scheduled' },
        { id: 3, homeTeam: { name: 'EE.UU.', flag: 'usa.png' }, awayTeam: { name: 'Paraguay', flag: 'par.png' }, date: '2026-06-12', time: '21:00 Hrs.', venue: 'SoFi Stadium', city: 'Los Angeles', phase: 'group', group: 'Grupo D', status: 'scheduled' },
        { id: 4, homeTeam: { name: 'Brasil', flag: 'bra.png' }, awayTeam: { name: 'Marruecos', flag: 'mar.png' }, date: '2026-06-13', time: '18:00 Hrs.', venue: 'MetLife Stadium', city: 'New York/NJ', phase: 'group', group: 'Grupo C', status: 'scheduled' },
    ];
}

// Agrupar por fecha
const groupedMatches: any = matches.reduce((acc: any, match: any) => {
    if (!acc[match.date]) acc[match.date] = [];
    acc[match.date].push(match);
    return acc;
}, {});

const sortedDates = Object.keys(groupedMatches).sort();
---

<Layout title="Calendario | Mundial 2026">
    <div class="relative min-h-screen">
        <BackgroundBlobs />

        <div class="relative z-10 max-w-[1100px] mx-auto px-6 md:px-0 pt-16 md:pt-8 pb-4">
            <header class="">
                <div class="flex items-center gap-3">
                    <div class="w-12 h-1.5 bg-gold rounded-full"></div>
                    <h2 class="text-gold font-bold tracking-[6px] uppercase text-[0.7rem] md:text-sm">Calendario</h2>
                </div>
            </header>
        </div>

        <!-- Visual Calendar Ribbon Filter -->
        <VisualCalendar activeDates={sortedDates} />

        <div class="relative z-10 max-w-[1100px] mx-auto px-0 pb-16 md:pb-8">
            <!-- Timeline Container -->
            <div class="relative flex flex-col gap-24" id="timeline-container">
                <!-- No Results Message -->
                <div id="no-results-message" class="hidden flex-col items-center justify-center py-20 text-center animate-fade-in">
                    <div class="w-16 h-16 rounded-full bg-white/5 flex items-center justify-center mb-6 text-white/30 border border-white/10">
                        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                    </div>
                    <h3 class="font-bebas text-3xl md:text-4xl text-white tracking-widest mb-2">No hay partidos</h3>
                    <p class="text-white/50 text-sm max-w-sm px-6">Ningún partido coincide con los filtros de fecha, grupo y equipo.</p>
                </div>

                {sortedDates.map((date, index) => (
                    <div class="timeline-day-group transition-all duration-500 ease-in-out" data-date={date}>
                        <TimelineRow 
                            date={date as string} 
                            dayMatches={groupedMatches[date as string]} 
                            index={index} 
                            isLast={index === sortedDates.length - 1} 
                        />
                    </div>
                ))}
            </div>
        </div>
    </div>
</Layout>
