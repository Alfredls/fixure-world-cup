---
import Layout from "../layouts/Layout.astro";
import LiveMatch from "../components/LiveMatch.astro";
import CompactMatchCard from "../components/CompactMatchCard.astro";
import GroupNav from "../components/GroupNav.astro";

import { getNextMatchDate, getMatchesByDate } from "../lib/db";
import { formatMatchDate, formatMatchTime } from "../lib/dateUtils";

// 1. Obtener la fecha del próximo partido disponible (hoy o en el futuro)
const today = new Date().toISOString().split('T')[0];
const targetDate = await getNextMatchDate(today) || '2026-06-11';

// 2. Obtener todos los partidos de esa fecha
const matchesData = await getMatchesByDate(targetDate);
  
// 3. Preparar datos para los componentes
let liveMatchData;
let dailyMatches = [];

if (matchesData && matchesData.length > 0) {
  // El primer partido del día es el "Hero" (simulamos que es el principal)
  const heroMatchRow = matchesData[0];
  const home = heroMatchRow.home_team;
  const away = heroMatchRow.away_team;

  const formattedDate = formatMatchDate(heroMatchRow.match_date);
  const formattedTime = formatMatchTime(heroMatchRow.match_time);
  
  // Si la fase es 'group', mostramos 'Grupo A', etc. Usamos group_id de la tabla matches.
  const phase = heroMatchRow.phase === 'group' 
    ? `Grupo ${heroMatchRow.group_id}` 
    : (heroMatchRow.phase?.toUpperCase() || "GRUPO");

  liveMatchData = {
    id: heroMatchRow.id,
    homeTeam: {
      name: home?.name || "TBD",
      flag: home?.flag_emoji || "unk.png",
    },
    awayTeam: {
      name: away?.name || "TBD",
      flag: away?.flag_emoji || "unk.png",
    },
    score: {
      home: heroMatchRow.home_score || 0,
      away: heroMatchRow.away_score || 0,
    },
    status: `${formattedDate} | ${formattedTime} | ${phase}`,
    penalties: heroMatchRow.penalties || null,
  };

  // Los demás partidos van al carrusel inferior
  dailyMatches = matchesData.slice(1).map((m) => {
    return {
      homeTeam: {
        name: m.home_team?.name || "TBD",
        flag: m.home_team?.flag_emoji || "unk.png",
      },
      awayTeam: {
        name: m.away_team?.name || "TBD",
        flag: m.away_team?.flag_emoji || "unk.png",
      },
      score: { home: m.home_score || 0, away: m.away_score || 0 },
    };
  });
} else {
  // Fallback mocks si no hay nada en la DB
  liveMatchData = {
    homeTeam: { name: "México", flag: "mex.png" },
    awayTeam: { name: "Sudáfrica", flag: "rsa.png" },
    score: { home: 0, away: 0 },
    status: "PRÓXIMO PARTIDO | 11 JUN | GRUPO A",
  };

  dailyMatches = [
    {
      homeTeam: { name: "Corea", flag: "kor.png" },
      awayTeam: { name: "TBD", flag: "unk.png" },
      score: { home: 0, away: 0 },
    },
  ];
}
---

<Layout title="Partidos">
  <!-- Background Stadium Image strictly grayscale/muted -->
  <div class="fixed inset-0 z-0">
    <img
      src="./bg.webp"
      alt="stadium bg"
      class="w-full h-full object-cover opacity-25 object-bottom"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-[#111111]/80 via-transparent to-[#111111]"></div>
  </div>

  <div class="relative z-10 flex flex-col min-h-[calc(90vh-80px)] justify-center">
    <!-- Central Live Match -->
    <div class="flex flex-col justify-center">
      <LiveMatch {...liveMatchData} />
    </div>

    <!-- Bottom Areas Container -->
    <div class="w-full flex flex-col gap-6">
      <!-- Other Matches Of The Day -->
      <div class="w-full flex flex-col mt-4 lg:mt-12 mb-4">
        <h4 class="text-gold font-bold tracking-[3px] uppercase mb-8 text-center text-3xl" > Partidos del día</h4>
        <div class="flex items-center justify-start md:justify-center gap-6 overflow-x-auto no-scrollbar pb-6 relative px-6 md:px-0 snap-x snap-mandatory">
          {dailyMatches.map((match) => <CompactMatchCard {...match} />)}
        </div>
      </div>

      <!-- Group Navigation Bottom Bar -->
      <GroupNav />
    </div>
  </div>
</Layout>

