---
// Redirect to admin if already logged in
import { createClient } from '@supabase/supabase-js';

const accessToken = Astro.cookies.get('sb-access-token')?.value;
if (accessToken) {
  const supabase = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
  );
  const { data: { user } } = await supabase.auth.getUser(accessToken);
  if (user) {
    return Astro.redirect('/admin');
  }
}

// Validar que nextUrl sea una ruta interna (previene open redirect)
const rawNext = Astro.url.searchParams.get('next') || '/admin';
const nextUrl = rawNext.startsWith('/') && !rawNext.startsWith('//') ? rawNext : '/admin';
const errorParam = Astro.url.searchParams.get('error');
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Login | Pasión Mundial</title>
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;600;700&display=swap" rel="stylesheet" />
    <style>
      :root {
        --gold: #ceab52;
        --dark: #111111;
        --card: #1c1c1e;
      }
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        background: var(--dark);
        color: white;
        font-family: 'Inter', sans-serif;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1rem;
        background-image: radial-gradient(ellipse at 50% 0%, rgba(206,171,82,0.08) 0%, transparent 60%);
      }
      .container {
        width: 100%;
        max-width: 420px;
      }
      .logo {
        font-family: 'Bebas Neue', cursive;
        font-size: 2.5rem;
        letter-spacing: 4px;
        color: var(--gold);
        text-align: center;
        margin-bottom: 0.5rem;
      }
      .subtitle {
        text-align: center;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 3px;
        color: rgba(255,255,255,0.4);
        margin-bottom: 2.5rem;
      }
      .card {
        background: var(--card);
        border-radius: 16px;
        padding: 2rem;
        border: 1px solid rgba(255,255,255,0.07);
        box-shadow: 0 24px 48px rgba(0,0,0,0.4);
      }
      .card-title {
        font-size: 0.65rem;
        text-transform: uppercase;
        letter-spacing: 3px;
        color: var(--gold);
        margin-bottom: 1.5rem;
      }
      .form-group {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        margin-bottom: 1rem;
      }
      label {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: rgba(255,255,255,0.5);
      }
      input[type="email"],
      input[type="password"] {
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 10px;
        padding: 0.85rem 1rem;
        color: white;
        font-family: 'Inter', sans-serif;
        font-size: 0.95rem;
        width: 100%;
        transition: border-color 0.2s, background 0.2s;
        outline: none;
      }
      input[type="email"]:focus,
      input[type="password"]:focus {
        border-color: var(--gold);
        background: rgba(206,171,82,0.06);
      }
      .btn-login {
        width: 100%;
        padding: 0.9rem;
        background: var(--gold);
        color: #111;
        font-family: 'Bebas Neue', cursive;
        font-size: 1.1rem;
        letter-spacing: 3px;
        border: none;
        border-radius: 10px;
        cursor: pointer;
        margin-top: 0.5rem;
        transition: opacity 0.2s, transform 0.1s;
      }
      .btn-login:hover { opacity: 0.9; }
      .btn-login:active { transform: scale(0.99); }
      .btn-login:disabled { opacity: 0.5; cursor: not-allowed; }
      .error-msg {
        background: rgba(255, 70, 70, 0.1);
        border: 1px solid rgba(255, 70, 70, 0.3);
        border-radius: 8px;
        padding: 0.75rem 1rem;
        font-size: 0.8rem;
        color: #ff7070;
        margin-bottom: 1rem;
        display: none;
      }
      .error-msg.visible { display: block; }
      .spinner {
        display: none;
        width: 18px;
        height: 18px;
        border: 2px solid rgba(17,17,17,0.3);
        border-top-color: #111;
        border-radius: 50%;
        animation: spin 0.7s linear infinite;
        margin: 0 auto;
      }
      .btn-login.loading .btn-text { display: none; }
      .btn-login.loading .spinner { display: block; }
      @keyframes spin { to { transform: rotate(360deg); } }
      .back-link {
        display: block;
        text-align: center;
        margin-top: 1.5rem;
        font-size: 0.75rem;
        color: rgba(255,255,255,0.3);
        text-decoration: none;
        letter-spacing: 1px;
        transition: color 0.2s;
      }
      .back-link:hover { color: rgba(255,255,255,0.6); }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="logo">Pasión Mundial</div>
      <p class="subtitle">Panel de Administración</p>

      <div class="card">
        <p class="card-title">🔐 Acceso Restringido</p>

        {errorParam === 'unauthorized' && (
          <div class="error-msg visible">
            Tu cuenta no tiene permisos de administrador.
          </div>
        )}

        <div id="error-container" class="error-msg"></div>

        <form id="login-form">
          <div class="form-group">
            <label for="email">Correo Electrónico</label>
            <input
              type="email"
              id="email"
              name="email"
              placeholder="admin@tudominio.com"
              required
              autocomplete="email"
            />
          </div>
          <div class="form-group">
            <label for="password">Contraseña</label>
            <input
              type="password"
              id="password"
              name="password"
              placeholder="••••••••"
              required
              autocomplete="current-password"
            />
          </div>
          <button type="submit" class="btn-login" id="login-btn">
            <span class="btn-text">Entrar al Panel</span>
            <div class="spinner"></div>
          </button>
        </form>
      </div>

      <a href="/" class="back-link">← Volver al sitio</a>
    </div>



    <script define:vars={{ supabaseUrl: import.meta.env.PUBLIC_SUPABASE_URL, supabaseAnon: import.meta.env.PUBLIC_SUPABASE_ANON_KEY, nextUrl }}>
      const form = document.getElementById('login-form');
      const btnLogin = document.getElementById('login-btn');
      const errorContainer = document.getElementById('error-container');

      function showError(msg) {
        errorContainer.textContent = msg;
        errorContainer.classList.add('visible');
      }

      function clearError() {
        errorContainer.textContent = '';
        errorContainer.classList.remove('visible');
      }

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        clearError();
        btnLogin.classList.add('loading');
        btnLogin.disabled = true;

        const email = document.getElementById('email').value;
        const password = document.getElementById('password').value;

        try {
          const response = await fetch(`${supabaseUrl}/auth/v1/token?grant_type=password`, {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'apikey': supabaseAnon,
            },
            body: JSON.stringify({ email, password }),
          });

          const data = await response.json();

          if (!response.ok || data.error) {
            const message = data.error_description || data.error || 'Credenciales incorrectas';
            showError(message === 'Invalid login credentials'
              ? 'Email o contraseña incorrectos'
              : message);
            btnLogin.classList.remove('loading');
            btnLogin.disabled = false;
            return;
          }

          // Guardar tokens en cookies (7 días)
          const expires = new Date(Date.now() + 7 * 24 * 60 * 60 * 1000).toUTCString();
          document.cookie = `sb-access-token=${data.access_token}; path=/; expires=${expires}; SameSite=Strict; Secure`;
          document.cookie = `sb-refresh-token=${data.refresh_token}; path=/; expires=${expires}; SameSite=Strict; Secure`;

          window.location.href = nextUrl;
        } catch (err) {
          showError('Error de conexión. Intenta de nuevo.');
          btnLogin.classList.remove('loading');
          btnLogin.disabled = false;
        }
      });
    </script>
  </body>
</html>
