---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { createClient } from '@supabase/supabase-js';

const user = Astro.locals.user;

const supabase = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
);

// Obtener todos los grupos con sus posiciones
const { data: groups } = await supabase
  .from('groups')
  .select('id, name')
  .order('name');

const { data: standings } = await supabase
  .from('standings')
  .select(`
    group_id, played, won, drawn, lost, goals_for, goals_against, goal_diff, points, qualified,
    team:teams(name, flag_emoji)
  `)
  .order('points', { ascending: false })
  .order('goal_diff', { ascending: false })
  .order('goals_for', { ascending: false });

// Agrupar standings por grupo
const standingsByGroup: Record<string, any[]> = {};
(standings || []).forEach((s: any) => {
  if (!standingsByGroup[s.group_id]) standingsByGroup[s.group_id] = [];
  standingsByGroup[s.group_id].push(s);
});
---

<AdminLayout title="Posiciones" user={user}>
  <div class="flex items-center gap-4 mb-8 bg-white/5 border border-white/10 p-4 rounded-xl">
    <div class="w-10 h-10 rounded-full bg-gold/10 flex items-center justify-center text-gold">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
    </div>
    <div>
      <h2 class="text-sm font-bold text-white mb-0.5 tracking-tight">Cálculo de Posiciones</h2>
      <p class="text-[0.65rem] text-white/40 uppercase tracking-widest font-medium">Actualización automática al finalizar partidos</p>
    </div>
  </div>

  <div class="groups-grid">
    {(groups || []).map((group: any) => {
      const groupStandings = standingsByGroup[group.id] || [];
      return (
        <div class="group-card">
          <div class="group-header">
            <span>GRUPO {group.id}</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="opacity-30"><path d="M6 9H4a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2v-2"/><rect width="14" height="14" x="8" y="2" rx="2"/><path d="M18 9v2"/><path d="M14 9v2"/><path d="M10 9v2"/></svg>
          </div>
          <table class="standings-table">
            <thead>
              <tr>
                <th class="w-10"></th>
                <th class="text-left pl-4">Equipo</th>
                <th>PJ</th>
                <th>G</th>
                <th>E</th>
                <th>P</th>
                <th>DG</th>
                <th>PTS</th>
              </tr>
            </thead>
            <tbody>
              {groupStandings.map((s: any, idx: number) => {
                const team = Array.isArray(s.team) ? s.team[0] : s.team;
                const isQualified = idx < 2;
                return (
                  <tr>
                    <td>
                      <span class={`pos-badge ${isQualified ? 'qualified' : ''}`}>
                        {isQualified ? (
                           <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                        ) : idx + 1}
                      </span>
                    </td>
                    <td class="team-cell-full">
                      <span class="font-medium text-white/90">{team?.name}</span>
                    </td>
                    <td>{s.played}</td>
                    <td>{s.won}</td>
                    <td>{s.drawn}</td>
                    <td>{s.lost}</td>
                    <td class={s.goal_diff > 0 ? 'text-green-400/80 font-bold' : s.goal_diff < 0 ? 'text-red-400/80' : 'opacity-40'}>
                      {s.goal_diff > 0 ? '+' : ''}{s.goal_diff}
                    </td>
                    <td class="pts-bold font-bebas text-lg tracking-wider">{s.points}</td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      );
    })}
  </div>
</AdminLayout>
