---
import AdminLayout from '../../layouts/AdminLayout.astro';

const user = Astro.locals.user;
---

<AdminLayout title="Sincronizar API" user={user}>
  <div class="sync-card">
    <div class="sync-header-box">
      <div class="sync-icon-main">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 0 0-9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/><path d="M3 12a9 9 0 0 0 9 9 9.75 9.75 0 0 0 6.74-2.74L21 16"/><path d="M16 16h5v5"/></svg>
      </div>
      <div>
        <h2 class="sync-title">Sincronización de Resultados</h2>
        <p class="text-[0.65rem] text-white/20 uppercase tracking-[0.2em] font-bold">Actualización en tiempo real desde API de Fútbol</p>
      </div>
    </div>

    <p class="sync-desc">
      Este proceso actualizará los goles y estados de los partidos programados para la fecha actual. 
      Utiliza el servicio de <strong>Football-Data.org</strong> para centralizar la información oficial del torneo.
    </p>

    <button id="sync-btn" class="sync-btn">
      <div class="spinner hidden" id="spin"></div>
      <svg id="btn-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
      <span id="btn-text">INICIAR PROCESO DE SINCRONIZACIÓN</span>
    </button>

    <div class="sync-log" id="sync-log"></div>

    <div class="api-info-grid">
      <div class="api-info-item">
        <span class="api-info-label">Fuente de datos</span>
        <span class="api-info-val">football-data.org</span>
      </div>
      <div class="api-info-item">
        <span class="api-info-label">Torneo</span>
        <span class="api-info-val">FIFA World Cup 2026</span>
      </div>
      <div class="api-info-item">
        <span class="api-info-label">Límite API</span>
        <span class="api-info-val">10 req/min (Standard)</span>
      </div>
      <div class="api-info-item">
        <span class="api-info-label">Último proceso</span>
        <span class="api-info-val" id="last-sync">Pendiente</span>
      </div>
    </div>
  </div>

  <style>
    .spinner {
      width: 16px; height: 16px;
      border: 3px solid rgba(0,0,0,0.1);
      border-top-color: #111;
      border-radius: 50%;
      animation: spin 0.7s linear infinite;
    }
    @keyframes spin { to { transform: rotate(360deg); } }
    .hidden { display: none; }
  </style>

  <script define:vars={{ supabaseUrl: import.meta.env.PUBLIC_SUPABASE_URL, supabaseAnon: import.meta.env.PUBLIC_SUPABASE_ANON_KEY }}>
    const btn = document.getElementById('sync-btn');
    const spin = document.getElementById('spin');
    const btnIcon = document.getElementById('btn-icon');
    const btnText = document.getElementById('btn-text');
    const log = document.getElementById('sync-log');
    const lastSync = document.getElementById('last-sync');

    function appendLog(msg, color = '#4ade80') {
      const time = new Date().toLocaleTimeString('es');
      const line = document.createElement('div');
      line.style.color = color;
      line.style.marginBottom = '2px';
      line.textContent = `[${time}] ${msg}`;
      log.appendChild(line);
      log.scrollTop = log.scrollHeight;
    }

    function getCookie(name) {
      const match = document.cookie.match(new RegExp('(^| )' + name + '=([^;]+)'));
      return match ? match[2] : null;
    }

    btn.addEventListener('click', async () => {
      btn.disabled = true;
      spin.classList.remove('hidden');
      btnIcon.classList.add('hidden');
      btnText.textContent = 'PROCESANDO DATOS...';
      log.classList.add('visible');
      log.textContent = '';

      appendLog('> Conectando con servidor de sincronización...');

      try {
        const token = getCookie('sb-access-token');
        const res = await fetch('/api/sync-matches', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Authorization': `Bearer ${token}`,
          },
        });

        const data = await res.json();

        if (!res.ok) {
          appendLog(`! ERROR CRÍTICO: ${data.error || 'Fallo en la respuesta del servidor'}`, '#f87171');
        } else {
          appendLog(`✓ Respuesta recibida correctamente`);
          appendLog(`✓ Partidos actualizados: ${data.updated ?? 0}`);
          appendLog(`✓ Partidos detectados en vivo: ${data.live ?? 0}`);
          if (data.message) appendLog(`i Mensaje: ${data.message}`, '#ceab52');
          appendLog(`> Sincronización completada con éxito`);
          lastSync.textContent = new Date().toLocaleString('es');
        }
      } catch (err) {
        appendLog(`! ERROR DE RED: ${err.message}`, '#f87171');
      }

      btn.disabled = false;
      spin.classList.add('hidden');
      btnIcon.classList.remove('hidden');
      btnText.textContent = 'INICIAR PROCESO DE SINCRONIZACIÓN';
    });
  </script>
</AdminLayout>
