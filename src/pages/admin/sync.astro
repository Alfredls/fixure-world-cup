---
import AdminLayout from '../../layouts/AdminLayout.astro';

const user = Astro.locals.user;
---

<AdminLayout title="Sincronizar API" user={user}>
  <style>
    .sync-card {
      background: #18181b;
      border: 1px solid rgba(255,255,255,0.07);
      border-radius: 16px;
      padding: 2rem;
      max-width: 600px;
    }
    .sync-title {
      font-family: 'Bebas Neue', cursive;
      font-size: 1.3rem;
      letter-spacing: 3px;
      color: white;
      margin-bottom: 0.5rem;
    }
    .sync-desc {
      font-size: 0.82rem;
      color: rgba(255,255,255,0.4);
      line-height: 1.6;
      margin-bottom: 1.5rem;
    }
    .sync-btn {
      padding: 0.8rem 1.5rem;
      background: #ceab52;
      color: #111;
      font-family: 'Bebas Neue', cursive;
      font-size: 1rem;
      letter-spacing: 2px;
      border: none;
      border-radius: 10px;
      cursor: pointer;
      transition: opacity 0.2s;
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
    }
    .sync-btn:hover { opacity: 0.9; }
    .sync-btn:disabled { opacity: 0.5; cursor: not-allowed; }
    .spinner {
      display: none;
      width: 16px; height: 16px;
      border: 2px solid rgba(17,17,17,0.3);
      border-top-color: #111;
      border-radius: 50%;
      animation: spin 0.7s linear infinite;
    }
    @keyframes spin { to { transform: rotate(360deg); } }
    .sync-log {
      margin-top: 1.5rem;
      background: rgba(0,0,0,0.4);
      border: 1px solid rgba(255,255,255,0.07);
      border-radius: 8px;
      padding: 1rem;
      font-family: 'Courier New', monospace;
      font-size: 0.75rem;
      color: #4ade80;
      min-height: 100px;
      max-height: 300px;
      overflow-y: auto;
      white-space: pre-wrap;
      display: none;
    }
    .sync-log.visible { display: block; }
    .divider {
      border: none;
      border-top: 1px solid rgba(255,255,255,0.07);
      margin: 1.5rem 0;
    }
    .api-info {
      font-size: 0.75rem;
      color: rgba(255,255,255,0.3);
      line-height: 1.7;
    }
    .api-info strong { color: rgba(255,255,255,0.55); }
  </style>

  <div class="sync-card">
    <h2 class="sync-title">🔄 Sincronización de Resultados</h2>
    <p class="sync-desc">
      Presiona el botón para actualizar los resultados del día actual desde la API de fútbol.
      Solo afecta partidos en estado "En Vivo" o "Programado" para la fecha de hoy.
    </p>

    <button id="sync-btn" class="sync-btn">
      <div class="spinner" id="spin"></div>
      <span id="btn-text">⚡ Sincronizar Ahora</span>
    </button>

    <div class="sync-log" id="sync-log"></div>

    <hr class="divider" />

    <div class="api-info">
      <p><strong>Fuente de datos:</strong> API de Football (football-data.org)</p>
      <p><strong>Torneo:</strong> FIFA World Cup 2026</p>
      <p><strong>Límite gratuito:</strong> 10 req/min (suficiente para actualizaciones manuales)</p>
      <p><strong>Última sincronización:</strong> <span id="last-sync">Nunca</span></p>
    </div>
  </div>

  <script define:vars={{ supabaseUrl: import.meta.env.PUBLIC_SUPABASE_URL, supabaseAnon: import.meta.env.PUBLIC_SUPABASE_ANON_KEY }}>
    const btn = document.getElementById('sync-btn');
    const spin = document.getElementById('spin');
    const btnText = document.getElementById('btn-text');
    const log = document.getElementById('sync-log');
    const lastSync = document.getElementById('last-sync');

    function appendLog(msg, color = '#4ade80') {
      const time = new Date().toLocaleTimeString('es');
      log.textContent += `[${time}] ${msg}\n`;
      log.scrollTop = log.scrollHeight;
    }

    // Get access token from cookie
    function getCookie(name) {
      const match = document.cookie.match(new RegExp('(^| )' + name + '=([^;]+)'));
      return match ? match[2] : null;
    }

    btn.addEventListener('click', async () => {
      btn.disabled = true;
      spin.style.display = 'block';
      btnText.textContent = 'Sincronizando...';
      log.classList.add('visible');
      log.textContent = '';

      appendLog('Iniciando sincronización...');

      try {
        const token = getCookie('sb-access-token');
        const res = await fetch('/api/sync-matches', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Authorization': `Bearer ${token}`,
          },
        });

        const data = await res.json();

        if (!res.ok) {
          appendLog(`ERROR: ${data.error || 'Error desconocido'}`, '#f87171');
        } else {
          appendLog(`✅ Sincronización completada`);
          appendLog(`   Partidos actualizados: ${data.updated ?? 0}`);
          appendLog(`   Partidos en vivo: ${data.live ?? 0}`);
          if (data.message) appendLog(`   Nota: ${data.message}`);
          lastSync.textContent = new Date().toLocaleString('es');
        }
      } catch (err) {
        appendLog(`ERROR de red: ${err.message}`, '#f87171');
      }

      btn.disabled = false;
      spin.style.display = 'none';
      btnText.textContent = '⚡ Sincronizar Ahora';
    });
  </script>
</AdminLayout>
