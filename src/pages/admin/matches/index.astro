---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { createClient } from '@supabase/supabase-js';
import Pagination from '../../../components/admin/Pagination.astro';

const user = Astro.locals.user;

const supabase = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
);

// Filtros desde URL
const phase = Astro.url.searchParams.get('phase') || '';
const status = Astro.url.searchParams.get('status') || '';
const dateFilter = Astro.url.searchParams.get('date') || '';
const page = parseInt(Astro.url.searchParams.get('page') || '1');
const pageSize = parseInt(Astro.url.searchParams.get('pageSize') || '10');
const from = (page - 1) * pageSize;
const to = from + pageSize - 1;

// Base query for counting
let countQuery = supabase
  .from('matches')
  .select('*', { count: 'exact', head: true });

if (status) countQuery = countQuery.eq('status', status);
if (phase) countQuery = countQuery.eq('phase', phase);
if (dateFilter) countQuery = countQuery.eq('match_date', dateFilter);

const { count: totalMatches } = await countQuery;

// Base query for data
let query = supabase
  .from('matches')
  .select(`
    id, match_date, match_time, status, home_score, away_score, phase, group_id,
    home_team:teams!home_team_id(name, flag_emoji),
    away_team:teams!away_team_id(name, flag_emoji)
  `)
  .order('match_date', { ascending: true })
  .order('match_time', { ascending: true })
  .range(from, to);

if (status) query = query.eq('status', status);
if (phase) query = query.eq('phase', phase);
if (dateFilter) query = query.eq('match_date', dateFilter);

const { data: matches } = await query;
---

<AdminLayout title="Partidos" user={user}>
  <!-- Filters -->
  <form method="GET" class="filters">
    <div class="relative flex items-center">
      <select name="status" class="filter-select !pl-10">
        <option value="" selected={!status}>Todos los estados</option>
        <option value="scheduled" selected={status === 'scheduled'}>Programados</option>
        <option value="live" selected={status === 'live'}>En Vivo</option>
        <option value="finished" selected={status === 'finished'}>Finalizados</option>
      </select>
      <div class="absolute left-3 pointer-events-none opacity-40">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
      </div>
    </div>

    <div class="relative flex items-center">
      <select name="phase" class="filter-select !pl-10">
        <option value="" selected={!phase}>Todas las fases</option>
        <option value="group" selected={phase === 'group'}>Grupos</option>
        <option value="Dieciseisavos de Final" selected={phase === 'Dieciseisavos de Final'}>R32</option>
        <option value="Octavos de Final" selected={phase === 'Octavos de Final'}>R16</option>
        <option value="Cuartos de Final" selected={phase === 'Cuartos de Final'}>Cuartos</option>
        <option value="Semifinales" selected={phase === 'Semifinales'}>Semis</option>
        <option value="Final" selected={phase === 'Final'}>Final</option>
      </select>
      <div class="absolute left-3 pointer-events-none opacity-40">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 12h8"/><path d="M12 8v8"/></svg>
      </div>
    </div>

    <input type="date" name="date" class="filter-input" value={dateFilter} />

    <button type="submit" class="filter-btn flex items-center gap-2">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/></svg>
      Filtrar
    </button>
  </form>

  <!-- Table -->
  <div class="card-wrapper">
    <div class="table-responsive">
      <table class="matches-table">
        <thead>
          <tr>
            <th>Fecha</th>
            <th>Hora</th>
            <th>Local</th>
            <th>Marcador</th>
            <th>Visitante</th>
            <th>Fase</th>
            <th>Estado</th>
            <th class="w-20"></th>
          </tr>
        </thead>
        <tbody>
          {matches?.map((m: any) => {
            const home = Array.isArray(m.home_team) ? m.home_team[0] : m.home_team;
            const away = Array.isArray(m.away_team) ? m.away_team[0] : m.away_team;
            return (
              <tr class="match-row">
                <td class="text-white/40">{m.match_date}</td>
                <td class="text-white/40">{m.match_time?.slice(0,5)}</td>
                <td class="font-medium text-white">{home?.name}</td>
                <td class="score-col font-bebas text-lg">
                  {m.status === 'scheduled'
                    ? <span class="text-white/20">-</span>
                    : `${m.home_score ?? 0} - ${m.away_score ?? 0}`
                  }
                </td>
                <td class="font-medium text-white">{away?.name}</td>
                <td class="text-white/40">
                  {m.phase === 'group' ? `Gr. ${m.group_id}` : m.phase}
                </td>
                <td>
                  <span class={`badge badge-${m.status} flex items-center gap-1.5 w-fit`}>
                    {m.status === 'live' && (
                      <span class="w-1.5 h-1.5 rounded-full bg-green-400 animate-pulse"></span>
                    )}
                    {m.status === 'finished' && (
                      <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                    )}
                    {m.status === 'scheduled' && (
                      <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/></svg>
                    )}
                    {m.status === 'live' ? 'En Vivo' : m.status === 'finished' ? 'Final' : 'Prog.'}
                  </span>
                </td>
                <td>
                  <a href={`/admin/matches/${m.id}`} class="text-gold opacity-60 hover:opacity-100 font-medium transition-all">Editar</a>
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
    
    <Pagination 
      totalItems={totalMatches || 0} 
      pageSize={pageSize} 
      currentPage={page} 
    />
  </div>
</AdminLayout>
