---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { createClient } from '@supabase/supabase-js';
import { supabaseAdmin } from '../../../lib/supabase.server';
import { Image } from 'astro:assets';
import { resolveFlag } from '../../../lib/flags';
import type { ImageMetadata } from 'astro';

const user = Astro.locals.user;
const { id } = Astro.params;

const supabase = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
);

// Obtener el partido
const { data: match, error } = await supabase
  .from('matches')
  .select(`
    *,
    home_team:teams!home_team_id(name, flag_emoji),
    away_team:teams!away_team_id(name, flag_emoji),
    venue:venues(name, city)
  `)
  .eq('id', id)
  .single();

if (error || !match) {
  return Astro.redirect('/admin/matches');
}

// Procesar resultado del formulario POST
let successMsg = '';
let errorMsg = '';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const homeScoreStr = formData.get('home_score');
  const awayScoreStr = formData.get('away_score');
  const statusStr = formData.get('status');

  // VALIDACIÓN: Si no hay SERVICE_ROLE_KEY, el cliente admin no funcionará
  if (!import.meta.env.SUPABASE_SERVICE_ROLE_KEY) {
    errorMsg = "ERROR: La clave SUPABASE_SERVICE_ROLE_KEY no está configurada en .env";
  } else {
    // 1. Limpiar datos (mantenemos como string para el UPDATE directo)
    const updateData: Record<string, any> = { 
      status: statusStr as string 
    };

    // Si vuelve a programado (scheduled), reseteamos a 0
    if (statusStr === 'scheduled') {
      updateData.home_score = 0;
      updateData.away_score = 0;
    } else {
      // Solo añadimos los goles si no están vacíos
      if (homeScoreStr !== '' && homeScoreStr !== null) {
        updateData.home_score = parseInt(homeScoreStr as string, 10);
      }
      if (awayScoreStr !== '' && awayScoreStr !== null) {
        updateData.away_score = parseInt(awayScoreStr as string, 10);
      }
    }

    // 2. Ejecutar actualización (PASAMOS EL ID TAL CUAL VIENE DEL PARAMS)
    const { error: updateError } = await supabaseAdmin
      .from('matches')
      .update(updateData)
      .eq('id', id);

    if (updateError) {
      errorMsg = `Error de Base de Datos: ${updateError.message}`;
    } else {
      // 3. Redirigir para refrescar datos
      return Astro.redirect(`/admin/matches/${id}?success=1`);
    }
  }
}

// Mostrar mensaje de éxito si viene de la URL
if (Astro.url.searchParams.get('success')) {
  successMsg = 'Partido actualizado correctamente';
}

const home = Array.isArray(match.home_team) ? match.home_team[0] : match.home_team;
const away = Array.isArray(match.away_team) ? match.away_team[0] : match.away_team;
const venue = Array.isArray(match.venue) ? match.venue[0] : match.venue;
---

<AdminLayout title="Editar Partido" user={user}>
  <div class="max-w-[850px] mx-auto py-8">
    <a href="/admin/matches" class="back-link group flex items-center mb-6">
      <div class="w-8 h-8 rounded-full border border-white/5 bg-white/5 flex items-center justify-center mr-3 group-hover:border-gold/50 group-hover:bg-gold/10 transition-all">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-40 group-hover:opacity-100 group-hover:text-gold transition-all"><path d="m15 18-6-6 6-6"/></svg>
      </div>
      <span class="opacity-40 group-hover:opacity-100 transition-all font-semibold text-[0.65rem] tracking-[0.2em] uppercase">Volver al Listado</span>
    </a>

    <!-- Match Preview Header -->
    <div class="match-header relative overflow-hidden backdrop-blur-md bg-white/[0.02]">
      <div class="absolute inset-0 bg-gradient-to-r from-gold/5 via-transparent to-gold/5 opacity-30 pointer-events-none"></div>
      
      <div class="team-display z-10">
        <div class="flag-container">
          {home?.flag_emoji?.endsWith('.png') ? (
            <Image src={resolveFlag(home.flag_emoji) as ImageMetadata} alt={home.name} class="flag-img" />
          ) : (
            <div class="flex items-center justify-center h-full bg-white/5 text-2xl">{home?.flag_emoji}</div>
          )}
        </div>
        <span class="name text-xl">{home?.name}</span>
      </div>
      
      <div class="flex-1 z-10 px-4">
        <div class="vs-score text-5xl md:text-6xl mb-2">
          {match.status === 'scheduled' 
            ? 'VS' 
            : `${match.home_score ?? 0} — ${match.away_score ?? 0}`
          }
        </div>
        <div class="px-3 py-1 bg-white/5 rounded-full inline-block border border-white/10 mb-3">
          <div class="match-meta !mt-0 !text-[0.6rem] font-bold text-gold/80">{match.match_date} · {match.match_time?.slice(0,5)} HS</div>
        </div>
        <div class="match-meta text-white/40 font-medium italic !text-[0.75rem]">{venue?.name}, {venue?.city}</div>
      </div>

      <div class="team-display z-10">
        <div class="flag-container">
          {away?.flag_emoji?.endsWith('.png') ? (
            <Image src={resolveFlag(away.flag_emoji) as ImageMetadata} alt={away.name} class="flag-img" />
          ) : (
            <div class="flex items-center justify-center h-full bg-white/5 text-2xl">{away?.flag_emoji}</div>
          )}
        </div>
        <span class="name text-xl">{away?.name}</span>
      </div>
    </div>

    <!-- Main Update Form -->
    <div class="form-card backdrop-blur-xl bg-white/[0.03] border-white/10 shadow-2xl">
      <div class="flex items-center gap-3 mb-8 border-b border-white/5 pb-4">
        <div class="w-2 h-2 bg-gold rounded-full animate-pulse"></div>
        <p class="form-title !mb-0">GESTIÓN DE RESULTADO Y ESTADO</p>
      </div>

      {successMsg && (
        <div class="alert alert-success flex items-center gap-3 animate-in fade-in slide-in-from-top-4 duration-500">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/><path d="m9 12 2 2 4-4"/></svg>
          {successMsg}
        </div>
      )}
      {errorMsg && (
        <div class="alert alert-error flex items-center gap-3 animate-in shake duration-500">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" x2="12" y1="8" y2="12"/><line x1="12" x2="12.01" y1="16" y2="16"/></svg>
          {errorMsg}
        </div>
      )}

      <form method="POST">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 mb-12">
          <div class="form-group flex flex-col items-center">
            <div class="flex items-center gap-2 mb-4">
              <span class="w-1.5 h-1.5 rounded-full bg-white/20"></span>
              <label class="text-[0.65rem] text-white/40 uppercase tracking-[0.3em] font-bold">Local: {home?.name}</label>
            </div>
            <div class="score-control group">
              <button type="button" class="score-btn decrement" data-target="home_score">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/></svg>
              </button>
              <input
                type="number"
                id="home_score"
                name="home_score"
                class="score-input group-hover:text-gold transition-colors"
                min="0" max="99"
                value={match.home_score ?? 0}
              />
              <button type="button" class="score-btn increment" data-target="home_score">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"/></svg>
              </button>
            </div>
          </div>
          
          <div class="form-group flex flex-col items-center">
            <div class="flex items-center gap-2 mb-4">
              <span class="w-1.5 h-1.5 rounded-full bg-white/20"></span>
              <label class="text-[0.65rem] text-white/40 uppercase tracking-[0.3em] font-bold">Visitante: {away?.name}</label>
            </div>
            <div class="score-control group">
              <button type="button" class="score-btn decrement" data-target="away_score">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/></svg>
              </button>
              <input
                type="number"
                id="away_score"
                name="away_score"
                class="score-input group-hover:text-gold transition-colors"
                min="0" max="99"
                value={match.away_score ?? 0}
              />
              <button type="button" class="score-btn increment" data-target="away_score">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"/></svg>
              </button>
            </div>
          </div>
        </div>

        <div class="form-group mb-12">
          <label class="text-[0.65rem] text-gold/30 mb-5 block uppercase tracking-[0.3em] font-bold text-center">Estado del encuentro</label>
          <div class="status-grid !grid-cols-1 md:!grid-cols-3 !gap-5">
            <label class="status-option group/opt">
              <input type="radio" name="status" value="scheduled" checked={match.status === 'scheduled'} />
              <div class="status-card h-full justify-center group-hover/opt:bg-white/5">
                <div class="status-icon">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/></svg>
                </div>
                <span class="label-text">Programado</span>
                <span class="description">El partido aún no ha comenzado</span>
              </div>
            </label>
            <label class="status-option group/opt live">
              <input type="radio" name="status" value="live" checked={match.status === 'live'} />
              <div class="status-card h-full justify-center group-hover/opt:bg-red-500/5">
                <div class="status-icon">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2zm0 18a8 8 0 1 1 8-8 8 8 0 0 1-8 8z"/><circle cx="12" cy="12" r="3"/></svg>
                </div>
                <span class="label-text">En Vivo</span>
                <span class="description">Actualización de goles en tiempo real</span>
              </div>
            </label>
            <label class="status-option group/opt">
              <input type="radio" name="status" value="finished" checked={match.status === 'finished'} />
              <div class="status-card h-full justify-center group-hover/opt:bg-gold/5">
                <div class="status-icon">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/><path d="m9 12 2 2 4-4"/></svg>
                </div>
                <span class="label-text">Finalizado</span>
                <span class="description">Se consolidan los puntos en las tablas</span>
              </div>
            </label>
          </div>
        </div>

        <button type="submit" class="submit-btn w-full flex items-center justify-center gap-4 py-5 hover:scale-[1.01] active:scale-[0.98] transition-all shadow-2xl relative group overflow-hidden">
          <div class="absolute inset-0 bg-white/10 translate-y-full group-hover:translate-y-0 transition-transform duration-300"></div>
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="rotate-0 group-hover:rotate-12 transition-transform"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
          <span class="font-bold tracking-[0.1em]">CONSOLIDAR ACTUALIZACIÓN</span>
        </button>
      </form>
    </div>
  </div>
</AdminLayout>

<script>
  function setupScoreControls() {
    const buttons = document.querySelectorAll('.score-btn');
    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        const targetId = btn.getAttribute('data-target');
        if (!targetId) return;
        const input = document.getElementById(targetId) as HTMLInputElement;
        if (!input) return;

        let value = parseInt(input.value) || 0;
        if (btn.classList.contains('increment')) {
          value++;
        } else if (btn.classList.contains('decrement')) {
          value = Math.max(0, value - 1);
        }
        input.value = value.toString();
      });
    });
  }

  setupScoreControls();
  document.addEventListener('astro:page-load', setupScoreControls);
</script>
