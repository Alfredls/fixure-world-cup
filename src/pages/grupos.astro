---
import Layout from '../layouts/Layout.astro';
import GroupCard from '../components/GroupCard.astro';
import { supabase } from '../lib/supabase';

// Intentar obtener datos de Supabase
let groups = [];
const { data: groupsData, error } = await supabase
	.from('groups')
	.select('id, name, teams(id, name, flag_emoji)')
    .order('name', { ascending: true });

if (!error && groupsData && groupsData.length > 0) {
    groups = groupsData;
} else {
	// Mocks iniciales si no hay datos (Mundial 2026 preliminar)
	groups = [
		{ id: 'A', name: 'Grupo A', teams: [{id: '1', name: 'México', flag_emoji: '🇲🇽'}, {id: '2', name: 'Sudáfrica', flag_emoji: '🇿🇦'}, {id: '3', name: 'Corea Sur', flag_emoji: '🇰🇷'}, {id: '4', name: 'PO Winner', flag_emoji: '❔'}] },
		{ id: 'B', name: 'Grupo B', teams: [{id: '5', name: 'Canadá', flag_emoji: '🇨🇦'}, {id: '6', name: 'Suiza', flag_emoji: '🇨🇭'}, {id: '7', name: 'Qatar', flag_emoji: '🇶🇦'}, {id: '8', name: 'PO Winner', flag_emoji: '❔'}] },
		{ id: 'C', name: 'Grupo C', teams: [{id: '9', name: 'Brasil', flag_emoji: '🇧🇷'}, {id: '10', name: 'Marruecos', flag_emoji: '🇲🇦'}, {id: '11', name: 'Escocia', flag_emoji: '🏴󠁧󠁢󠁳󠁣󠁴󠁿'}, {id: '12', name: 'Haití', flag_emoji: '🇭🇹'}] },
		{ id: 'D', name: 'Grupo D', teams: [{id: '13', name: 'EE.UU.', flag_emoji: '🇺🇸'}, {id: '14', name: 'Australia', flag_emoji: '🇦🇺'}, {id: '15', name: 'Paraguay', flag_emoji: '🇵🇾'}, {id: '16', name: 'PO Winner', flag_emoji: '❔'}] },
        { id: 'E', name: 'Grupo E', teams: [{id: '17', name: 'Argentina', flag_emoji: '🇦🇷'}, {id: '18', name: 'Bélgica', flag_emoji: '🇧🇪'}, {id: '19', name: 'Irán', flag_emoji: '🇮🇷'}, {id: '20', name: 'PO Winner', flag_emoji: '❔'}] },
	];
}
---

<Layout title="Grupos">
	<header class="text-center mb-12">
		<h1 class="text-4xl md:text-6xl mb-2 font-bebas">GRUPOS DEL MUNDIAL</h1>
		<p class="text-muted text-lg">Las 48 selecciones divididas en 12 grupos de 4.</p>
	</header>

	<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8">
		{groups.map((group) => (
			<GroupCard id={group.id} name={group.name} teams={group.teams} />
		))}
	</div>
</Layout>

