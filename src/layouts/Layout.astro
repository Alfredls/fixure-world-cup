---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;

const pathname = new URL(Astro.request.url).pathname;
const isHome = pathname === '/' || pathname === '/index.html';
const isGroups = pathname.startsWith('/grupos') || pathname.startsWith('/grupo/');
const isHistorial = pathname.startsWith('/historial') || pathname.startsWith('/bracket');
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Fixture Personalizado Mundial 2026" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | Mundial 2026</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-[#111] text-white font-inter min-h-screen flex flex-col relative">
    
    <!-- Top Header Navigation -->
    <header class="w-full h-[80px] z-[100] border-b border-white/5 bg-[#111]/80 backdrop-blur-md sticky top-0">
      <nav class="max-w-[1400px] mx-auto h-full flex items-center justify-between px-6 lg:px-12">
        <!-- Logo -->
        <a href="/" class="font-bebas text-3xl tracking-widest text-[#ceab52] mt-2">
          WORLD CUP
        </a>
        
        <!-- Center Nav -->
        <ul class="hidden md:flex items-center gap-10 h-full">
          <li class="h-full flex items-center pt-2">
            <a href="/" class={`text-sm tracking-wide ${isHome ? 'text-[#ceab52] border-b-2 border-[#ceab52] pb-[8px]' : 'text-white/80 hover:text-white transition-colors pb-2 cursor-pointer'}`}>Partidos</a>
          </li>
          <li class="h-full flex items-center pt-2">
            <a href="/partidos" class={`text-sm tracking-wide ${pathname.startsWith('/partidos') ? 'text-[#ceab52] border-b-2 border-[#ceab52] pb-[8px]' : 'text-white/80 hover:text-white transition-colors pb-2 cursor-pointer'}`}>Calendario</a>
          </li>
          <li class="h-full flex items-center pt-2">
            <a href="/grupos" class={`text-sm tracking-wide ${isGroups ? 'text-[#ceab52] border-b-2 border-[#ceab52] pb-[8px]' : 'text-white/80 hover:text-white transition-colors pb-2 cursor-pointer'}`}>Grupos</a>
          </li>
          <li class="h-full flex items-center pt-2">
            <a href="/historial" class={`text-sm tracking-wide ${isHistorial ? 'text-[#ceab52] border-b-2 border-[#ceab52] pb-[8px]' : 'text-white/80 hover:text-white transition-colors pb-2 cursor-pointer'}`}>Historial</a>
          </li>
        </ul>
        
        <!-- Right Icon -->
        <div class="text-white/70 hover:text-white transition-colors cursor-pointer pt-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.3-4.3"></path></svg>
        </div>
      </nav>
    </header>

    <main class="flex-1 w-full max-w-[1400px] mx-auto px-6 lg:px-12 flex flex-col relative z-20 py-8 lg:py-12">
      <slot />
    </main>

  </body>
</html>
