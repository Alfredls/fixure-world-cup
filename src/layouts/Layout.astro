---
import Header from "../components/Header.astro";
import { ClientRouter } from 'astro:transitions';
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  image?: string;
  fullWidth?: boolean;
  noPadding?: boolean;
}

const { 
  title, 
  description = "Fixture Personalizado Mundial 2026. Fechas, grupos y el camino a la gran final.", 
  image = "/favicon.svg",
  fullWidth, 
  noPadding 
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || "https://pasionmundial2026.com");
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Primary Meta Tags -->
    <title>{title} | Pasión Mundial</title>
    <meta name="title" content={`${title} | Pasión Mundial`} />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={`${title} | Pasión Mundial`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.url)} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={`${title} | Pasión Mundial`} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL(image, Astro.url)} />
    
    <meta name="theme-color" content="#111111" />

    <script>
      import { isTransitionBeforePreparationEvent } from 'astro:transitions/client';

      // Global Loading Bar Logic
      let progress = 0;
      let timer: ReturnType<typeof setInterval>;

      function startLoading() {
        const bar = document.getElementById('loading-bar');
        if (!bar) return;
        
        document.body.classList.add('loading-bar-active');
        progress = 10;
        bar.style.width = `${progress}%`;
        
        timer = setInterval(() => {
          progress += Math.random() * 5;
          if (progress > 90) progress = 90;
          bar.style.width = `${progress}%`;
        }, 200);
      }

      function finishLoading() {
        const bar = document.getElementById('loading-bar');
        if (!bar) return;
        
        clearInterval(timer);
        progress = 100;
        bar.style.width = '100%';
        
        setTimeout(() => {
          document.body.classList.remove('loading-bar-active');
          setTimeout(() => {
            bar.style.width = '0%';
          }, 300);
        }, 200);
      }

      // Astro Navigation Hooks
      document.addEventListener('astro:before-preparation', () => {
        startLoading();
      });

      document.addEventListener('astro:after-preparation', () => {
        // Preparation is done (HTML loaded), but transition hasn't started
      });

      document.addEventListener('astro:page-load', () => {
        finishLoading();
      });
    </script>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;600;700&display=swap"
      rel="stylesheet"
    />

    <ClientRouter />
  </head>
  <body class="bg-[#111] text-white font-inter min-h-screen flex flex-col relative" >
    <div id="loading-bar-container">
      <div id="loading-bar"></div>
    </div>

    <Header />

    <main class:list={[
      "flex-1 w-full flex flex-col relative z-20",
      { "max-w-[1400px] mx-auto px-6 lg:px-12 py-8 lg:py-12": !fullWidth },
      { "p-0 overflow-hidden": fullWidth }
    ]}>
      <slot />
    </main>
  </body>
</html>
