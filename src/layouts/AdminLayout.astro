---
import '../styles/admin.css';
import Toast from '../components/Toast.astro';

interface Props {
  title: string;
  user?: { email?: string };
}

const { title, user } = Astro.props;
const pathname = new URL(Astro.request.url).pathname;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Admin — Pasión Mundial</title>
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <div class="admin-layout">
      <!-- Sidebar -->
      <aside class="sidebar" id="admin-sidebar">
        <div class="sidebar-logo">
          <a href="/">Pasión Mundial</a>
          <span class="sidebar-badge">Panel Admin</span>
        </div>
        <nav class="sidebar-nav">
          <span class="nav-section">General</span>
          <a href="/admin" class={`nav-link ${pathname === '/admin' ? 'active' : ''}`}>
            <span class="icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="7" height="9" x="3" y="3" rx="1"/><rect width="7" height="5" x="14" y="3" rx="1"/><rect width="7" height="9" x="14" y="12" rx="1"/><rect width="7" height="5" x="3" y="15" rx="1"/></svg>
            </span> 
            Dashboard
          </a>
          <a href="/admin/matches" class={`nav-link ${pathname.startsWith('/admin/matches') ? 'active' : ''}`}>
            <span class="icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m10 11.5 1.5 1.5-1.5 1.5"/><path d="M16 12h-4"/></svg>
            </span> 
            Partidos
          </a>
          <a href="/admin/standings" class={`nav-link ${pathname.startsWith('/admin/standings') ? 'active' : ''}`}>
            <span class="icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="m19 9-7 7-3-3-4 4"/></svg>
            </span> 
            Posiciones
          </a>
          
          <span class="nav-section mt-4">Herramientas</span>
          <a href="/admin/sync" class={`nav-link ${pathname.startsWith('/admin/sync') ? 'active' : ''}`}>
            <span class="icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 0 0-9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/><path d="M3 12a9 9 0 0 0 9 9 9.75 9.75 0 0 0 6.74-2.74L21 16"/><path d="M16 16h5v5"/></svg>
            </span> 
            Sincronizar API
          </a>
        </nav>
        <div class="sidebar-footer">
          <div class="user-info">
            <div class="user-avatar">{user?.email?.[0]?.toUpperCase() || 'A'}</div>
            <div class="user-email">{user?.email || 'Admin'}</div>
          </div>
          <a href="/admin/logout" class="btn-logout flex items-center justify-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" x2="9" y1="12" y2="12"/></svg>
            Cerrar Sesión
          </a>
        </div>
      </aside>

      <!-- Mobile overlay -->
      <div class="sidebar-overlay" id="sidebar-overlay"></div>

      <!-- Main Area -->
      <div class="admin-main">
        <div class="admin-topbar">
          <button class="mobile-menu-btn" id="mobile-menu-btn" aria-label="Menú">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
          </button>
          <span class="page-title">{title}</span>
        </div>
        <div class="admin-content">
          <Toast />
          <slot />
        </div>
      </div>
    </div>

    <script>
      const sidebar = document.getElementById('admin-sidebar');
      const overlay = document.getElementById('sidebar-overlay');
      const menuBtn = document.getElementById('mobile-menu-btn');

      menuBtn?.addEventListener('click', () => {
        sidebar?.classList.toggle('open');
        overlay?.classList.toggle('visible');
      });

      overlay?.addEventListener('click', () => {
        sidebar?.classList.remove('open');
        overlay?.classList.remove('visible');
      });
    </script>
  </body>
</html>
