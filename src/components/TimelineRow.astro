---
import { getDayInfo } from '../lib/dateUtils';

interface Props {
    date: string;
    dayMatches: any[];
    index: number;
    isLast: boolean;
}

const { date, dayMatches, index, isLast } = Astro.props;
const info = getDayInfo(date);

// FIFA 26 Color Palette
const palette = [
    '#00f2ff', // Cyan
    '#9d00ff', // Purple
    '#ff003c', // Red
    '#00ff8c', // Green
    '#ffdc00', // Yellow
    '#ceab52'  // Gold
];

function getDateColor(i: number) {
    return palette[i % palette.length];
}

const color = getDateColor(index);
const nextColor = getDateColor(index + 1);
---

<div class="relative z-10 flex flex-col sm:flex-row gap-8 md:gap-16 group">
    <!-- Left: Date & Timeline Segment -->
    <div class="flex flex-row sm:flex-col items-center sm:items-start min-w-[100px] md:min-w-[120px] relative">
        <!-- Segmented Line -->
        {!isLast && (
            <div 
                class="absolute left-[50px] sm:left-1/2 top-24 bottom-[-96px] w-[2px] z-0 hidden sm:block opacity-30"
                style={`background: linear-gradient(to bottom, ${color}, ${nextColor})`}
            ></div>
        )}
        
        <!-- Date Marker -->
        <div class="sticky top-24 z-20 flex flex-row sm:flex-col items-center gap-4 sm:gap-1 py-4 w-full justify-center rounded-2xl border border-white/10 bg-[#0a0a0a]" style={`background-color: ${color}15`} >
            <span class="text-xs font-black uppercase tracking-[3px] opacity-40 day-label">{info.dayName}</span>
            <span class="text-6xl md:text-7xl font-bebas text-white leading-none tracking-tight">{info.dayNumber}</span>
            <div class="flex flex-col sm:items-center">
                <span class="text-[0.65rem] md:text-[0.75rem] text-white/40 uppercase font-bold tracking-widest leading-none">{info.monthName}</span>
            </div>
        </div>
    </div>

    <!-- Right: Matches -->
    <div class="flex-1 flex flex-col gap-8 ml-4 sm:ml-0">
        {dayMatches.map((match: any) => (
            <div class="relative group/match">
                <div 
                    class="absolute -left-4 sm:-left-8 top-1/2 -translate-y-1/2 w-1.5 h-12 rounded-full opacity-0 group-hover/match:opacity-100 transition-all duration-500 shadow-[0_0_15px_rgba(0,0,0,0.5)]"
                    style={`background-color: ${color}`}
                ></div>

                <div class="bg-white/[0.03] border border-white/5 rounded-[40px] p-4 md:p-6 backdrop-blur-2xl hover:border-white/20 transition-all duration-700 relative overflow-hidden group/card shadow-2xl">
                    <div 
                        class="absolute inset-0 opacity-0 group-hover/card:opacity-10 transition-opacity duration-700 pointer-events-none"
                        style={`background: radial-gradient(circle at center, ${color}, transparent 80%)`}
                    ></div>

                    <div class="flex items-center gap-2 mb-8 text-[0.7rem] font-black tracking-[3px] uppercase justify-center">
                        <span class="text-gold">{match.group} • {match.phase === 'group' ? 'Fase de Grupos' : match.phase.toUpperCase()}</span>
                    </div>

                    <div class="flex flex-col lg:flex-row lg:items-center justify-between gap-10 mb-5">
                        <div class="flex items-center gap-6 group/team">
                            <div class="w-16 h-16 rounded-full bg-white/5 p-1.5 border border-white/10 group-hover/card:border-white/30 transition-all duration-700 overflow-hidden shadow-2xl transform group-hover/card:scale-105">
                                <img src={match.homeTeam.flag.startsWith('http') ? match.homeTeam.flag : `/flags/${match.homeTeam.flag}`} alt="" class="w-full h-full object-cover rounded-full" />
                            </div>
                            <span class="text-xl md:text-2xl font-bebas text-white tracking-widest group-hover/card:text-white transition-colors duration-500">{match.homeTeam.name}</span>
                        </div>

                        <div class="flex items-center justify-center gap-6 opacity-20 group-hover/card:opacity-40 transition-opacity duration-700">
                            <div class="h-[1px] w-12 bg-white/50 hidden md:block"></div>
                            <span class="font-bebas text-4xl text-white">VS</span>
                            <div class="h-[1px] w-12 bg-white/50 hidden md:block"></div>
                        </div>

                        <div class="flex items-center lg:flex-row-reverse gap-6 group/team text-right">
                            <div class="w-16 h-16 rounded-full bg-white/5 p-1.5 border border-white/10 group-hover/card:border-white/30 transition-all duration-700 overflow-hidden shadow-2xl transform group-hover/card:scale-105">
                                <img src={match.awayTeam.flag.startsWith('http') ? match.awayTeam.flag : `/flags/${match.awayTeam.flag}`} alt="" class="w-full h-full object-cover rounded-full" />
                            </div>
                            <span class="text-xl md:text-2xl font-bebas text-white tracking-widest group-hover/card:text-white transition-colors duration-500">{match.awayTeam.name}</span>
                        </div>
                    </div>

                    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-6 pt-5 border-t border-white/5 ">
                        <div class="flex flex-col gap-2">
                            <div class="flex items-center gap-3 text-white/50 group-hover/card:text-white/80 transition-colors">
                                <div class="w-8 h-8 rounded-full bg-white/5 flex items-center justify-center border border-white/10 text-gold">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                                </div>
                                <span class="text-[0.8rem] font-black uppercase tracking-[2px]">{match.venue} | {match.city}</span> 
                            </div>
                        </div>

                        <div class="flex items-center gap-4  p-2 ">
                            <div class="w-10 h-10 rounded-full flex items-center justify-center text-black font-bold text-xs text-gold">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                            </div>
                            <span class="text-md font-normal text-white tracking-[3px]">{match.time}</span>
                        </div>
                    </div>
                </div>
            </div>
        ))}
    </div>
</div>
