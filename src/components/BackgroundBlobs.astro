---
---
<!-- Background Colorful Blobs -->
<div class="fixed inset-0 z-0 pointer-events-none overflow-hidden">
    <!-- Main colorful blobs -->
    <div class="absolute -top-[10%] -left-[10%] w-[50%] h-[50%] bg-[#00f2ff]/10 blur-[150px] rounded-full"></div>
    <div class="absolute top-[20%] -right-[10%] w-[40%] h-[40%] bg-[#9d00ff]/10 blur-[150px] rounded-full"></div>
    <div class="absolute -bottom-[10%] left-[20%] w-[60%] h-[60%] bg-[#ff003c]/5 blur-[200px] rounded-full"></div>
    
    <!-- Pattern overlay -->
    <div class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/carbon-fibre.png')] opacity-10 pointer-events-none"></div>
    
    <!-- Subtle grain/noise for depth if needed (optional) -->
    <div class="absolute inset-0 opacity-[0.03] pointer-events-none bg-[url('https://www.transparenttextures.com/patterns/natural-paper.png')]"></div>
</div>
