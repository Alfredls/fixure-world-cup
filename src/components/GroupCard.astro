---
interface Team {
	id: string;
	name: string;
	flag_emoji: string;
}

interface Props {
	id: string;
	name: string;
	teams: Team[];
}

const { id, name, teams } = Astro.props;
---

<div class="bg-dark-card p-6 rounded-xl border border-white/5 flex flex-col gap-4 shadow-lg hover:border-gold/30 hover:-translate-y-1 transition-all duration-300">
	<div class="flex justify-between items-center border-b border-white/10 pb-2 mb-2">
		<h3 class="text-2xl text-gold font-bebas">{name}</h3>
		<span class="font-black opacity-20 text-2xl">{id}</span>
	</div>
	<ul class="list-none flex flex-col gap-3">
		{teams.map((team) => (
			<li class="flex items-center gap-3 text-base font-medium">
				<span class="text-[1.4rem]">{team.flag_emoji}</span>
				<span class="text-white">{team.name}</span>
			</li>
		))}
	</ul>
	<a href={`/group/${id}`} class="mt-auto no-underline text-green-accent font-semibold text-[0.85rem] transition-colors duration-300 text-right hover:text-gold">
		View Details →
	</a>
</div>

