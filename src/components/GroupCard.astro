---
interface Team {
	id: string;
	name: string;
	flag_emoji: string;
}

interface Props {
	id: string;
	name: string;
	teams: Team[];
}

const { id, name, teams } = Astro.props;

// Map group ID to a theme color
const getGroupTheme = (groupId: string) => {
  const themes: Record<string, { color: string, border: string }> = {
    'A': { color: 'bg-blue-600', border: 'border-blue-500/30' },
    'B': { color: 'bg-green-600', border: 'border-green-500/30' },
    'C': { color: 'bg-red-600', border: 'border-red-500/30' },
    'D': { color: 'bg-yellow-500', border: 'border-yellow-500/30' },
    'E': { color: 'bg-slate-400', border: 'border-slate-400/30' },
    'F': { color: 'bg-zinc-800', border: 'border-zinc-800/30' },
    'G': { color: 'bg-purple-600', border: 'border-purple-500/30' },
    'H': { color: 'bg-orange-500', border: 'border-orange-500/30' },
    'I': { color: 'bg-cyan-600', border: 'border-cyan-500/30' },
    'J': { color: 'bg-pink-600', border: 'border-pink-500/30' },
    'K': { color: 'bg-emerald-600', border: 'border-emerald-500/30' },
    'L': { color: 'bg-indigo-600', border: 'border-indigo-500/30' },
  };
  return themes[groupId] || { color: 'bg-gold', border: 'border-gold/30' };
};

const theme = getGroupTheme(id);
---

<a href={`/group/${id}`} class="group no-underline block">
  <div class={`flex bg-dark-card/40 backdrop-blur-md rounded-xl overflow-hidden border ${theme.border} h-full min-h-[180px] shadow-2xl hover:bg-dark-card/60 transition-all duration-500 hover:scale-[1.02] hover:shadow-gold/10`}>
    
    <!-- Vertical Sidebar -->
    <div class={`w-12 md:w-14 ${theme.color} flex items-center justify-center relative overflow-hidden`}>
      <div class="absolute inset-0 bg-black/10"></div>
      <h3 class="font-bebas text-2xl md:text-3xl text-white -rotate-90 whitespace-nowrap tracking-widest drop-shadow-lg">
        GROUP {id}
      </h3>
    </div>

    <!-- Content Area -->
    <div class="flex-1 p-4 md:p-6 flex flex-col justify-center">
      <ul class="flex flex-col gap-3">
        {teams.map((team) => (
          <li class="flex items-center justify-between group/item">
            <div class="flex items-center gap-3">
              <div class="min-w-12 max-w-12 min-h-12 max-h-12 rounded-full bg-white/5 p-1.5 border border-white/10 shadow-2xl "> 
                <img src={`/flags/${team.flag_emoji}`} alt="" class="min-w-full min-h-full object-cover rounded-full aspect-square"> 
              </div>
              <span class="text-white/90 font-medium text-sm md:text-base tracking-tight group-hover/item:text-white transition-colors uppercase font-sans">
                {team.name}
              </span>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </div>
</a>

<style>
  /* Custom scrollbar handling or other tweaks if needed */
  h3 {
    text-shadow: 0 4px 8px rgba(0,0,0,0.3);
  }
</style>
