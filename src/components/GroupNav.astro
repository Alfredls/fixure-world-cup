---
const groups = ['Group A', 'Group B', 'Group C', 'Group D', 'Group E', 'Group F', 'Group G', 'Group H'];
---

<div class="w-full py-6 px-4 md:px-12 flex flex-col md:flex-row items-center gap-4 md:gap-8 relative z-[200] justify-center overflow-hidden">
  
  <h4 class="font-bebas text-gold text-2xl md:text-2xl tracking-[2px] uppercase whitespace-nowrap pt-1 text-center">GROUPS</h4>
  
  <div class="flex items-center relative group w-full md:w-auto">
    <!-- Left Navigation Button -->
    <button id="groups-prev" class="absolute left-0 top-1/2 -translate-y-1/2 z-20 p-2 text-white/50 hover:text-white transition-opacity opacity-0 disabled:pointer-events-none cursor-pointer bg-gradient-to-r from-black/80 to-transparent h-full flex items-center pr-4">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
    </button>

    <!-- Group Pills Container -->
    <div id="groups-scroll-container" class="flex items-center gap-3 overflow-x-auto no-scrollbar py-2 px-8 w-full md:w-fit snap-x snap-mandatory scroll-smooth">
      {groups.map((group, i) => (
        <a 
          href={`/group/${group.split(' ')[1]}`} 
          class={`px-6 py-2 rounded-full text-xs font-bold tracking-wider whitespace-nowrap transition-all bg-white/75 text-black hover:bg-gold hover:text-black snap-center`}
        >
          {group}
        </a>
      ))}
    </div>

    <!-- Right Navigation Button -->
    <button id="groups-next" class="absolute right-0 top-1/2 -translate-y-1/2 z-20 p-2 text-white/50 hover:text-white transition-opacity opacity-0 disabled:pointer-events-none cursor-pointer bg-gradient-to-l from-black/80 to-transparent h-full flex items-center pl-4">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
    </button>
  </div>
</div>

<script>
  function initGroupsNavigation() {
    const container = document.getElementById('groups-scroll-container');
    const prevBtn = document.getElementById('groups-prev') as HTMLButtonElement | null;
    const nextBtn = document.getElementById('groups-next') as HTMLButtonElement | null;

    if (!container || !prevBtn || !nextBtn) return;

    function updateArrowVisibility() {
        if (!container || !prevBtn || !nextBtn) return;
        const { scrollLeft, scrollWidth, clientWidth } = container;
        const hasOverflow = scrollWidth > (clientWidth + 5);

        if (!hasOverflow) {
            prevBtn.style.opacity = '0';
            nextBtn.style.opacity = '0';
            prevBtn.disabled = true;
            nextBtn.disabled = true;
        } else {
            const atStart = scrollLeft <= 5;
            const atEnd = scrollLeft + clientWidth >= scrollWidth - 10;

            prevBtn.style.opacity = atStart ? '0' : '1';
            nextBtn.style.opacity = atEnd ? '0' : '1';
            prevBtn.disabled = atStart;
            nextBtn.disabled = atEnd;
        }
    }

    prevBtn.addEventListener('click', () => {
        container.scrollBy({ left: -200, behavior: 'smooth' });
    });

    nextBtn.addEventListener('click', () => {
        container.scrollBy({ left: 200, behavior: 'smooth' });
    });

    container.addEventListener('scroll', updateArrowVisibility);
    
    // Initial and resize checks
    const resizeObserver = new ResizeObserver(updateArrowVisibility);
    resizeObserver.observe(container);
    
    // Fallback for initial load
    setTimeout(updateArrowVisibility, 100);
  }

  initGroupsNavigation();
  document.addEventListener('astro:page-load', initGroupsNavigation);
</script>
