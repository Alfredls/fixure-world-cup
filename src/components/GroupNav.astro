---
const groups = ['Grupo A', 'Grupo B', 'Grupo C', 'Grupo D', 'Grupo E', 'Grupo F', 'Grupo G', 'Grupo H'];
---

<div class="w-full bg-[#0d0d0f]/95 backdrop-blur-xl border-t border-white/5 py-3 px-6 md:px-12 flex items-center gap-8 relative z-[200]">
  
  <h4 class="font-bebas text-gold text-2xl tracking-[2px] uppercase whitespace-nowrap pt-1">FIXTURES</h4>
  
  <div class="flex items-center flex-1 overflow-hidden relative group">
    <!-- Left Fade / Button -->
    <div class="absolute left-0 top-0 bottom-0 w-12 bg-gradient-to-r from-[#0d0d0f] to-transparent z-10 flex items-center text-white/30 cursor-pointer hover:text-white transition-colors">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
    </div>

    <!-- Group Pills -->
    <div class="flex items-center gap-3 overflow-x-auto no-scrollbar py-2 px-8 w-full">
      {groups.map((group, i) => (
        <a 
          href={`/grupo/${group.split(' ')[1]}`} 
          class={`px-6 py-2 rounded-full text-xs font-bold tracking-wider whitespace-nowrap transition-all ${i === 0 ? 'bg-gold text-black' : 'bg-[#1c1c1e] text-white/60 hover:bg-[#2c2c2e] hover:text-white'}`}
        >
          {group}
        </a>
      ))}
    </div>

    <!-- Right Fade / Button -->
    <div class="absolute right-0 top-0 bottom-0 w-12 bg-gradient-to-l from-[#0d0d0f] to-transparent z-10 flex items-center justify-end text-white/30 cursor-pointer hover:text-white transition-colors">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
    </div>
  </div>
</div>
