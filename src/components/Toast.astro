---
/**
 * Toast.astro — Componente reutilizable de notificación temporal.
 * Muestra un toast si la URL contiene ?notif=<key>.
 *
 * Keys soportadas:
 *   not-found   → "Página no encontrada"
 *   unauthorized → "Sin permisos de acceso"
 */

const notifKey = Astro.url.searchParams.get('notif');

const messages: Record<string, { title: string; msg: string }> = {
  'not-found': {
    title: 'Página no encontrada',
    msg: 'La ruta que ingresaste no existe.',
  },
  'unauthorized': {
    title: 'Acceso denegado',
    msg: 'No tienes permisos para ver esa sección.',
  },
};

const notification = notifKey ? messages[notifKey] : null;
---

{notification && (
  <div id="notif-toast" class="notif-toast" role="alert" aria-live="polite">
    <div class="notif-icon">
      <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10"/>
        <line x1="12" y1="8" x2="12" y2="12"/>
        <line x1="12" y1="16" x2="12.01" y2="16"/>
      </svg>
    </div>
    <div class="notif-body">
      <span class="notif-title">{notification.title}</span>
      <span class="notif-msg">{notification.msg}</span>
    </div>
    <button id="notif-close" class="notif-close" title="Cerrar" aria-label="Cerrar notificación">
      <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"/>
        <line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
    <div class="notif-progress-bar" aria-hidden="true"></div>
  </div>
)}

<style>
  .notif-toast {
    position: fixed;
    top: 96px;
    right: 1.5rem;
    z-index: 500;
    display: flex;
    align-items: center;
    gap: 0.8rem;
    padding: 0.85rem 1rem;
    max-width: 320px;
    width: max-content;
    background: rgba(22, 22, 24, 0.95);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 14px;
    backdrop-filter: blur(20px);
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5), 0 0 0 1px rgba(255, 255, 255, 0.04);
    overflow: hidden;
    animation: toast-in 0.45s cubic-bezier(0.34, 1.56, 0.64, 1) both;
  }

  .notif-toast.toast-out {
    animation: toast-out 0.3s ease forwards;
    pointer-events: none;
  }

  @keyframes toast-in {
    from { opacity: 0; transform: translateX(calc(100% + 1.5rem)); }
    to   { opacity: 1; transform: translateX(0); }
  }

  @keyframes toast-out {
    from { opacity: 1; transform: translateX(0); }
    to   { opacity: 0; transform: translateX(calc(100% + 1.5rem)); }
  }

  .notif-icon {
    flex-shrink: 0;
    width: 30px;
    height: 30px;
    border-radius: 50%;
    background: rgba(248, 113, 113, 0.12);
    border: 1px solid rgba(248, 113, 113, 0.25);
    color: #f87171;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .notif-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    min-width: 0;
  }

  .notif-title {
    font-size: 0.8rem;
    font-weight: 700;
    color: #fff;
    white-space: nowrap;
  }

  .notif-msg {
    font-size: 0.7rem;
    color: rgba(255, 255, 255, 0.4);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .notif-close {
    flex-shrink: 0;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.05);
    color: rgba(255, 255, 255, 0.35);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.15s;
  }
  .notif-close:hover {
    background: rgba(255, 255, 255, 0.12);
    color: #fff;
  }

  /* Auto-dismiss progress bar at the bottom */
  .notif-progress-bar {
    position: absolute;
    bottom: 0;
    left: 0;
    height: 2px;
    width: 100%;
    background: rgba(206, 171, 82, 0.6);
    transform-origin: left;
    animation: progress-shrink 4s linear forwards;
  }

  @keyframes progress-shrink {
    from { transform: scaleX(1); }
    to   { transform: scaleX(0); }
  }

  @media (max-width: 480px) {
    .notif-toast {
      top: 88px;
      right: 1rem;
      left: 1rem;
      max-width: none;
      width: auto;
    }
    .notif-title, .notif-msg { white-space: normal; }
  }
</style>

<script>
  function initToast() {
    const toast = document.getElementById('notif-toast');
    if (!toast) return;

    // Limpiar ?notif de la URL sin recargar la página
    const url = new URL(window.location.href);
    if (url.searchParams.has('notif')) {
      url.searchParams.delete('notif');
      history.replaceState({}, '', url.toString());
    }

    // Auto-dismiss después de 4 segundos
    const autoDismiss = setTimeout(() => dismiss(), 4000);

    function dismiss() {
      clearTimeout(autoDismiss);
      if (!toast) return;
      toast.classList.add('toast-out');
      setTimeout(() => toast.remove(), 350);
    }

    document.getElementById('notif-close')?.addEventListener('click', dismiss);
  }

  document.addEventListener('astro:page-load', initToast);
</script>
