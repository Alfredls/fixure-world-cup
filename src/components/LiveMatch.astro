---
import TeamDisplay from './TeamDisplay.astro';

interface LiveMatchData {
  homeTeam: { name: string; flag: string };
  awayTeam: { name: string; flag: string };
  score: { home: number; away: number };
  status: string;
  penalties?: { home: number; away: number } | null;
}

interface Props {
  matches: LiveMatchData[];
}

const { matches } = Astro.props;

// For infinite loop, we clone the first item at the end
const extendedMatches = matches.length > 1 ? [...matches, matches[0]] : matches;
---

<div class="relative w-full overflow-hidden group/hero" id="hero-carousel" data-count={matches.length}>
  <!-- Navigation Arrows -->
  {matches.length > 1 && (
    <button id="prevBtn" class="absolute left-4 top-1/2 -translate-y-1/2 z-30 p-4 rounded-full bg-black/20 hover:bg-black/50 border border-white/10 text-white transition-all opacity-0 group-hover/hero:opacity-100 backdrop-blur-md">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
    </button>
    <button id="nextBtn" class="absolute right-4 top-1/2 -translate-y-1/2 z-30 p-4 rounded-full bg-black/20 hover:bg-black/50 border border-white/10 text-white transition-all opacity-0 group-hover/hero:opacity-100 backdrop-blur-md">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
    </button>
  )}

  <!-- Carousel Track -->
  <div id="carousel-track" class="flex transition-transform duration-700 ease-in-out">
    {extendedMatches.map((match) => (
      <div class="w-full flex-shrink-0 flex flex-col items-center justify-center font-inter py-[4vh]">
        
        <!-- Status Pill -->
        <div class="border border-gold/60 rounded-full px-6 py-1.5 mb-8 bg-black/40 backdrop-blur-md">
          <span class="text-gold text-[0.65rem] md:text-xs font-bold tracking-[2px] uppercase">{match.status}</span>
        </div>

        <!-- Main Match Area -->
        <div class="flex items-center justify-center gap-6 md:gap-14 w-full px-4 mb-2">
          
          <!-- Home Team Logo -->
          <TeamDisplay team={match.homeTeam} bgClass="bg-[#2a5b7c]" />

          <!-- Score Area -->
          <div class="flex flex-col items-center justify-center min-w-0 md:min-w-[200px]">
            <div class="flex items-center gap-2 md:gap-10 translate-y-[-20px] md:translate-y-0 ">
              <span class="text-6xl md:text-[8rem] font-bold text-white drop-shadow-md leading-none">{match.score.home}</span>
              <span class="text-xl md:text-2xl font-bold text-white/30 italic uppercase pt-4">vs</span>
              <span class="text-6xl md:text-[8rem] font-bold text-white drop-shadow-md leading-none">{match.score.away}</span>
            </div>
          </div>

          <!-- Away Team Logo -->
          <TeamDisplay team={match.awayTeam} bgClass="bg-[#1e2336]" nameClassName="justify-end" />
        </div>

        <!-- Penalties Row -->
        {match.penalties && (
          <div class="flex items-center gap-4 mt-2 mb-10">
            <div class="h-[1px] w-20 md:w-32 bg-gold/50"></div>
            <span class="text-white/50 text-[0.65rem] md:text-xs font-bold tracking-[3px] uppercase">Penalties ({match.penalties.home} - {match.penalties.away})</span>
            <div class="h-[1px] w-20 md:w-32 bg-gold/50"></div>
          </div>
        )}
      </div>
    ))}
  </div>

  <!-- Dots Indicators -->
  {matches.length > 1 && (
    <div class="absolute bottom-4 left-1/2 -translate-x-1/2 flex gap-3 z-30">
      {matches.map((_, i) => (
        <div 
          class={`carousel-dot w-2 h-2 rounded-full transition-all duration-300 ${i === 0 ? 'bg-gold w-6' : 'bg-white/20'}`}
          data-index={i}
        ></div>
      ))}
    </div>
  )}
</div>

<script>
  function initCarousel() {
    const track = document.getElementById('carousel-track');
    const container = document.getElementById('hero-carousel');
    const prevBtn = document.getElementById('prevBtn');
    const nextBtn = document.getElementById('nextBtn');
    const dots = document.querySelectorAll('.carousel-dot');
    
    if (!track || !container) return;

    const originalCount = parseInt(container.getAttribute('data-count') || '0');
    if (originalCount <= 1) return;

    let currentIndex = 0;
    let isTransitioning = false;

    function updateCarousel(instant = false) {
      if (instant) {
        track!.style.transition = 'none';
      } else {
        track!.style.transition = 'transform 0.7s ease-in-out';
      }
      
      track!.style.transform = `translateX(-${currentIndex * 100}%)`;
      
      // Update dots (modulo to keep within original count)
      const dotIndex = currentIndex % originalCount;
      dots.forEach((dot, i) => {
        if (i === dotIndex) {
          dot.classList.add('bg-gold', 'w-6');
          dot.classList.remove('bg-white/20');
        } else {
          dot.classList.remove('bg-gold', 'w-6');
          dot.classList.add('bg-white/20');
        }
      });
    }

    // Handles the jump from clone to actual start
    track.addEventListener('transitionend', () => {
      isTransitioning = false;
      if (currentIndex === originalCount) {
        currentIndex = 0;
        updateCarousel(true);
      }
    });

    function nextSlide() {
      if (isTransitioning) return;
      isTransitioning = true;
      currentIndex++;
      updateCarousel();
    }

    function prevSlide() {
      if (isTransitioning) return;
      isTransitioning = true;
      if (currentIndex === 0) {
        // Jump to clone instantly
        currentIndex = originalCount;
        updateCarousel(true);
        // Then slide to original last
        setTimeout(() => {
          currentIndex = originalCount - 1;
          updateCarousel();
        }, 1);
      } else {
        currentIndex--;
        updateCarousel();
      }
    }

    if (prevBtn) prevBtn.addEventListener('click', () => { prevSlide(); resetInterval(); });
    if (nextBtn) nextBtn.addEventListener('click', () => { nextSlide(); resetInterval(); });

    let autoPlayInterval: any;
    if (originalCount > 1) {
      autoPlayInterval = setInterval(nextSlide, 5000);
    }

    function resetInterval() {
      if (originalCount <= 1) return;
      clearInterval(autoPlayInterval);
      autoPlayInterval = setInterval(nextSlide, 5000);
    }

    // Pausar al pasar el mouse
    container.addEventListener('mouseenter', () => {
      if (originalCount > 1) clearInterval(autoPlayInterval);
    });

    container.addEventListener('mouseleave', () => {
      if (originalCount > 1) resetInterval();
    });
  }

  initCarousel();
  document.addEventListener('astro:page-load', initCarousel);
</script>
