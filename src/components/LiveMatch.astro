---
import TeamDisplay from './TeamDisplay.astro';

interface Props {
  homeTeam: { name: string; flag: string };
  awayTeam: { name: string; flag: string };
  score: { home: number; away: number };
  status: string;
  penalties?: { home: number; away: number };
}

const { homeTeam, awayTeam, score, status, penalties } = Astro.props;

---

<div class="w-full flex flex-col items-center justify-center font-inter py-[4vh]">
  
  <!-- Status Pill -->
  <div class="border border-gold/60 rounded-full px-6 py-1.5 mb-8">
    <span class="text-gold text-[0.65rem] md:text-xs font-bold tracking-[2px] uppercase">{status}</span>
  </div>

  <!-- Main Match Area -->
  <div class="flex items-center justify-center gap-6 md:gap-14 w-full px-4 mb-2">
    
    <!-- Home Team Logo -->
    <TeamDisplay team={homeTeam} bgClass="bg-[#2a5b7c]" />

    <!-- Score Area -->
    <div class="flex flex-col items-center justify-center min-w-0 md:min-w-[200px]">
      <div class="flex items-center gap-2 md:gap-10 translate-y-[-20px] md:translate-y-0 ">
        <span class="text-6xl md:text-[8rem] font-bold text-white drop-shadow-md leading-none">{score.home}</span>
        <span class="text-xl md:text-2xl font-bold text-white/30 italic uppercase pt-4">vs</span>
        <span class="text-6xl md:text-[8rem] font-bold text-white drop-shadow-md leading-none">{score.away}</span>
      </div>
    </div>

    <!-- Away Team Logo -->
    <TeamDisplay team={awayTeam} bgClass="bg-[#1e2336]" nameClassName="justify-end" />
  </div>

  <!-- Penalties Row -->
  {penalties && (
    <div class="flex items-center gap-4 mt-2 mb-10">
      <div class="h-[1px] w-20 md:w-32 bg-gold/50"></div>
      <span class="text-white/50 text-[0.65rem] md:text-xs font-bold tracking-[3px] uppercase">Penalties ({penalties.home} - {penalties.away})</span>
      <div class="h-[1px] w-20 md:w-32 bg-gold/50"></div>
    </div>
  )}
</div>
