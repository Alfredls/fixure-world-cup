---
interface Props {
  activeDates: string[];
}

const { activeDates } = Astro.props;

// Calculamos las fechas desde el primer hasta el último partido para la Cinta
const startStr = activeDates.length > 0 ? activeDates[0] : '2026-06-11';
const endStr = activeDates.length > 0 ? activeDates[activeDates.length - 1] : '2026-07-19';

const startDate = new Date(startStr + 'T12:00:00');
const endDate = new Date(endStr + 'T12:00:00');
const allDates: string[] = [];

let current = new Date(startDate);
while (current <= endDate) {
  const yyyy = current.getFullYear();
  const mm = String(current.getMonth() + 1).padStart(2, '0');
  const dd = String(current.getDate()).padStart(2, '0');
  allDates.push(`${yyyy}-${mm}-${dd}`);
  current.setDate(current.getDate() + 1);
}

// Helpers
const getDayName = (dateStr: string) => {
    const diasCorto = ['Dom', 'Lun', 'Mar', 'Mié', 'Jue', 'Vie', 'Sáb'];
    return diasCorto[new Date(dateStr + 'T12:00:00').getDay()];
};

const getDayNum = (dateStr: string) => dateStr.split('-')[2];

const getMonthName = (dateStr: string) => {
    const meses = ['Ene', 'Feb', 'Mar', 'Abr', 'May', 'Jun', 'Jul', 'Ago', 'Sep', 'Oct', 'Nov', 'Dic'];
    return meses[parseInt(dateStr.split('-')[1]) - 1];
};

// Generar Cuadrículas (Grid) de Junio y Julio 2026
function generateMonthDays(year: number, month: number) {
    const totalDays = new Date(year, month, 0).getDate();
    const firstDay = new Date(`${year}-${String(month).padStart(2, '0')}-01T12:00:00`).getDay(); 
    
    const days: (string | null)[] = [];
    for (let i = 0; i < firstDay; i++) days.push(null);
    for (let i = 1; i <= totalDays; i++) {
        days.push(`${year}-${String(month).padStart(2, '0')}-${String(i).padStart(2, '0')}`);
    }
    return days;
}

const juneDays = generateMonthDays(2026, 6);
const julyDays = generateMonthDays(2026, 7);
const daysOfWeek = ['D', 'L', 'M', 'M', 'J', 'V', 'S'];
---

<div class="visual-calendar-component w-full relative mb-16">
    
    <!-- Tab Controls -->
    <div class="flex justify-center mb-8 px-4">
        <div class="bg-white/5 p-1 rounded-full border border-white/10 flex items-center shadow-lg">
            <button class="calendar-tab-btn active px-6 py-2 rounded-full text-xs font-bold tracking-[2px] uppercase transition-all duration-300" data-target="view-ribbon">
                Vista Rápida
            </button>
            <button class="calendar-tab-btn px-6 py-2 rounded-full text-xs font-bold tracking-[2px] uppercase text-white/50 transition-all duration-300 hover:text-white" data-target="view-grid">
                Mes Completo
            </button>
        </div>
    </div>

    <!-- VIEW 1: RIBBON (Horizontal) -->
    <div id="view-ribbon" class="calendar-view block relative">
        <div class="absolute left-0 top-0 bottom-0 w-8 md:w-16 bg-gradient-to-r from-[#0a0a0a] to-transparent z-10 pointer-events-none"></div>
        <div class="absolute right-0 top-0 bottom-0 w-8 md:w-16 bg-gradient-to-l from-[#0a0a0a] to-transparent z-10 pointer-events-none"></div>

        <!-- Left Arrow -->
        <button id="ribbon-prev" class="absolute left-2 md:left-4 top-1/2 -translate-y-1/2 z-20 w-8 h-8 rounded-full bg-black/60 border border-white/20 flex items-center justify-center text-white hover:bg-gold/20 hover:text-gold hover:border-gold transition-colors outline-none shadow-xl hidden md:flex">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        </button>

        <div id="ribbon-container" class="calendar-scroll-area flex gap-3 overflow-x-auto snap-x hide-scrollbar px-6 md:px-16 py-6 scroll-smooth">
            
            <button 
                class="calendar-date-btn active snap-center flex flex-col items-center justify-center min-w-[70px] h-20 rounded-2xl border border-white/10 bg-transparent outline-none transition-all duration-300 hover:bg-white/5 shrink-0 group relative overflow-hidden"
                data-target-date="all"
            >
                <div class="w-6 h-6 rounded-full border border-white/30 flex items-center justify-center mb-1 group-hover:border-gold transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-white/50 group-hover:text-gold transition-colors"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg>
                </div>
                <span class="text-[0.55rem] font-bold tracking-[2px] uppercase text-white/50 pointer-events-none group-hover:text-white transition-colors">Todos</span>
            </button>

            {allDates.map((dateStr) => {
                const isActive = activeDates.includes(dateStr);
                return (
                    <button 
                        class={`calendar-date-btn snap-center flex flex-col items-center justify-center min-w-[70px] h-20 rounded-2xl border outline-none transition-all duration-300 shrink-0 relative
                        ${isActive 
                            ? 'bg-white/5 border-white/10 hover:border-gold/50 hover:bg-white/10 cursor-pointer' 
                            : 'bg-transparent border-white/5 opacity-30 cursor-not-allowed hover:opacity-50'}`}
                        data-target-date={isActive ? dateStr : ''}
                        disabled={!isActive}
                    >
                        {isActive && (
                            <div class="absolute -top-1.5 right-2 w-2.5 h-2.5 rounded-full bg-gold shadow-[0_0_12px_rgba(206,171,82,1)] animate-pulse pointer-events-none"></div>
                        )}
                        <span class="text-[0.6rem] font-bold tracking-widest uppercase text-white/50 pointer-events-none">{getDayName(dateStr)}</span>
                        <span class="text-2xl font-bebas text-white leading-none my-0.5 pointer-events-none">{getDayNum(dateStr)}</span>
                        <span class="text-[0.55rem] font-bold text-white/30 uppercase pointer-events-none">{getMonthName(dateStr)}</span>
                    </button>
                );
            })}
        </div>

        <!-- Right Arrow -->
        <button id="ribbon-next" class="absolute right-2 md:right-4 top-1/2 -translate-y-1/2 z-20 w-8 h-8 rounded-full bg-black/60 border border-white/20 flex items-center justify-center text-white hover:bg-gold/20 hover:text-gold hover:border-gold transition-colors outline-none shadow-xl hidden md:flex">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </button>
    </div>

    <!-- VIEW 2: GRID (Monthly) -->
    <div id="view-grid" class="calendar-view hidden pb-4 pt-4 px-4 xl:px-0">
        <div class="grid grid-cols-1 lg:grid-cols-[1fr_1fr_280px] gap-8 lg:gap-10 max-w-[1100px] mx-auto">
            
            <!-- JUNIO 2026 -->
            <div class="month-grid-wrapper bg-white/[0.02] border border-white/5 rounded-3xl p-6 md:p-8 backdrop-blur-md shadow-2xl">
                <div class="flex items-center gap-3 mb-6">
                    <div class="w-1.5 h-6 bg-gold rounded-full"></div>
                    <h3 class="text-2xl font-bebas tracking-widest text-white">JUNIO 2026</h3>
                </div>
                
                <div class="grid grid-cols-7 gap-1 md:gap-2 mb-2">
                    {daysOfWeek.map(d => (
                        <div class="text-center text-[0.65rem] font-bold text-white/30 uppercase tracking-widest pb-2">{d}</div>
                    ))}
                </div>
                <div class="grid grid-cols-7 gap-1 md:gap-2">
                    {juneDays.map(dateStr => {
                        if (!dateStr) return <div class="w-full aspect-square"></div>;
                        const isActive = activeDates.includes(dateStr);
                        return (
                            <button 
                                class={`calendar-date-btn relative w-full aspect-square flex items-center justify-center rounded-lg md:rounded-xl text-xs md:text-sm font-bold transition-all duration-300 outline-none
                                ${isActive 
                                    ? 'bg-white/5 border border-white/10 hover:border-gold/50 hover:bg-gold/10 text-white cursor-pointer hover:scale-110 shadow-lg' 
                                    : 'text-white/20 cursor-not-allowed hover:bg-white/5 border border-transparent'}
                                `}
                                data-target-date={isActive ? dateStr : ''}
                                disabled={!isActive}
                            >
                                {isActive && (
                                    <div class="absolute top-[2px] right-[2px] md:top-1 md:right-1 w-1.5 h-1.5 rounded-full bg-gold shadow-[0_0_8px_rgba(206,171,82,1)] pointer-events-none"></div>
                                )}
                                <span class="pointer-events-none font-bebas text-lg md:text-xl">{getDayNum(dateStr)}</span>
                            </button>
                        );
                    })}
                </div>
            </div>

            <!-- JULIO 2026 -->
            <div class="month-grid-wrapper bg-white/[0.02] border border-white/5 rounded-3xl p-6 md:p-8 backdrop-blur-md shadow-2xl">
                <div class="flex items-center gap-3 mb-6">
                    <div class="w-1.5 h-6 bg-gold rounded-full"></div>
                    <h3 class="text-2xl font-bebas tracking-widest text-white">JULIO 2026</h3>
                </div>
                
                <div class="grid grid-cols-7 gap-1 md:gap-2 mb-2">
                    {daysOfWeek.map(d => (
                        <div class="text-center text-[0.65rem] font-bold text-white/30 uppercase tracking-widest pb-2">{d}</div>
                    ))}
                </div>
                <div class="grid grid-cols-7 gap-1 md:gap-2">
                    {julyDays.map(dateStr => {
                        if (!dateStr) return <div class="w-full aspect-square"></div>;
                        const isActive = activeDates.includes(dateStr);
                        return (
                            <button 
                                class={`calendar-date-btn relative w-full aspect-square flex items-center justify-center rounded-lg md:rounded-xl text-xs md:text-sm font-bold transition-all duration-300 outline-none
                                ${isActive 
                                    ? 'bg-white/5 border border-white/10 hover:border-gold/50 hover:bg-gold/10 text-white cursor-pointer hover:scale-110 shadow-lg' 
                                    : 'text-white/20 cursor-not-allowed hover:bg-white/5 border border-transparent'}
                                `}
                                data-target-date={isActive ? dateStr : ''}
                                disabled={!isActive}
                            >
                                {isActive && (
                                    <div class="absolute top-[2px] right-[2px] md:top-1 md:right-1 w-1.5 h-1.5 rounded-full bg-gold shadow-[0_0_8px_rgba(206,171,82,1)] pointer-events-none"></div>
                                )}
                                <span class="pointer-events-none font-bebas text-lg md:text-xl">{getDayNum(dateStr)}</span>
                            </button>
                        );
                    })}
                </div>
            </div>

            <!-- FILTROS AVANZADOS -->
            <div class="filter-controls-wrapper flex flex-col gap-4 w-full lg:max-w-[280px]">
                <div class="p-6 md:p-8 bg-white/[0.02] border border-white/5 rounded-3xl backdrop-blur-md shadow-2xl flex flex-col gap-6 h-full">
                    <div class="flex items-center gap-3">
                        <div class="w-1.5 h-6 bg-gold rounded-full"></div>
                        <h3 class="text-xl font-bebas tracking-widest text-white uppercase">Filtros</h3>
                    </div>

                    <!-- Botón Limpiar Filtro -->
                    <button 
                        class="calendar-date-btn w-full flex items-center justify-center gap-2 px-6 py-3 rounded-xl border border-white/10 bg-transparent outline-none transition-all duration-300 hover:bg-white/5 group"
                        data-target-date="all"
                        id="btn-clear-filters"
                    >
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-white/50 group-hover:text-gold transition-colors"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg>
                        <span class="text-[0.7rem] font-bold tracking-[2px] uppercase text-white/50 pointer-events-none group-hover:text-white transition-colors flex-1 text-left">Limpiar Filtros</span>
                    </button>

                    <!-- Búsqueda por Grupo -->
                    <div class="flex flex-col gap-4">
                        <h4 class="text-[0.65rem] font-bold tracking-[2px] uppercase text-white/50">Por Grupo</h4>
                        <div class="relative group">
                            <select id="group-filter-select" class="w-full bg-black/40 border border-white/10 rounded-xl px-4 py-3 text-sm text-white focus:outline-none focus:border-gold hover:border-white/30 transition-colors appearance-none cursor-pointer">
                                <option value="all">Todos los grupos</option>
                                <option value="Grupo A">Grupo A</option>
                                <option value="Grupo B">Grupo B</option>
                                <option value="Grupo C">Grupo C</option>
                                <option value="Grupo D">Grupo D</option>
                                <option value="Grupo E">Grupo E</option>
                                <option value="Grupo F">Grupo F</option>
                                <option value="Grupo G">Grupo G</option>
                                <option value="Grupo H">Grupo H</option>
                                <option value="Grupo I">Grupo I</option>
                                <option value="Grupo J">Grupo J</option>
                                <option value="Grupo K">Grupo K</option>
                                <option value="Grupo L">Grupo L</option>
                            </select>
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="absolute right-4 top-1/2 -translate-y-1/2 text-white/30 pointer-events-none group-hover:text-gold transition-colors"><path d="m6 9 6 6 6-6"/></svg>
                        </div>
                    </div>

                    <!-- Búsqueda por Equipo -->
                    <div class="flex flex-col gap-4">
                        <h4 class="text-[0.65rem] font-bold tracking-[2px] uppercase text-white/50">Por Equipo</h4>
                        <div class="relative group">
                            <input id="team-search-input" type="text" placeholder="Buscar equipo..." class="w-full bg-black/40 border border-white/10 rounded-xl px-4 py-3 text-sm text-white focus:outline-none focus:border-gold hover:border-white/30 transition-colors placeholder:text-white/20" />
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="absolute right-4 top-1/2 -translate-y-1/2 text-white/30 group-hover:text-gold group-focus-within:text-gold transition-colors pointer-events-none"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>

</div>

<style>
    .hide-scrollbar {
        -ms-overflow-style: none;
        scrollbar-width: none;
    }
    .hide-scrollbar::-webkit-scrollbar {
        display: none;
    }
    
    /* Shared Active Style for both Ribbon and Grid buttons */
    .calendar-date-btn.active {
        background-color: rgba(206, 171, 82, 0.2) !important;
        border-color: #ceab52 !important;
        box-shadow: 0 0 20px rgba(206, 171, 82, 0.4);
        color: #ceab52 !important;
    }
    .calendar-date-btn.active span {
        color: #ceab52 !important;
    }
    
    /* Tab active style */
    .calendar-tab-btn.active {
        background: rgba(255, 255, 255, 0.1);
        color: white;
        box-shadow: 0 4px 15px rgba(0,0,0,0.5);
    }
</style>

<script>
    function initCalendar() {
        // --- 1. VIEW SWITCHER (TABS) ---
        const tabBtns = document.querySelectorAll('.calendar-tab-btn');
        const views = document.querySelectorAll('.calendar-view');

        tabBtns.forEach(btn => {
            btn.addEventListener('click', (e) => {
                const targetViewId = (e.target as HTMLElement).getAttribute('data-target');
                
                // Toggle Tab buttons
                tabBtns.forEach(b => {
                    b.classList.remove('active');
                    b.classList.add('text-white/50');
                });
                btn.classList.add('active');
                btn.classList.remove('text-white/50');

                // Toggle Views
                views.forEach(v => {
                    if (v.id === targetViewId) {
                        v.classList.remove('hidden');
                        v.classList.add('animate-fade-in'); 
                    } else {
                        v.classList.add('hidden');
                        v.classList.remove('animate-fade-in');
                    }
                });

                // Reset filters on tab switch
                const clearBtn = document.getElementById('btn-clear-filters');
                if (clearBtn) {
                    clearBtn.click();
                }
            });
        });

        // --- 2. RIBBON NAVIGATION ARROWS ---
        const ribbon = document.getElementById('ribbon-container');
        const prevBtn = document.getElementById('ribbon-prev');
        const nextBtn = document.getElementById('ribbon-next');

        if (ribbon && prevBtn && nextBtn) {
            const scrollAmount = 250;
            prevBtn.onclick = () => {
                ribbon.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
            };
            nextBtn.onclick = () => {
                ribbon.scrollBy({ left: scrollAmount, behavior: 'smooth' });
            };
        }

        // --- 3. GLOBAL FILTERING ---
        const dateButtons = document.querySelectorAll('.calendar-date-btn');
        const timelineGroups = document.querySelectorAll('.timeline-day-group');
        const groupSelect = document.getElementById('group-filter-select') as HTMLSelectElement;
        const teamSearch = document.getElementById('team-search-input') as HTMLInputElement;

        let currentActiveDate = 'all';
        let currentGroup = 'all';
        let currentTeam = '';

        function applyFilters() {
            let totalVisibleMatches = 0;

            timelineGroups.forEach((group: Element) => {
                const htmlGroup = group as HTMLElement;
                const groupDate = htmlGroup.getAttribute('data-date');
                let dayHasVisibleMatches = false;
                
                const matches = htmlGroup.querySelectorAll('.match-card-item');
                matches.forEach((match: Element) => {
                    const htmlMatch = match as HTMLElement;
                    const mGroup = htmlMatch.getAttribute('data-group') || '';
                    const mHome = htmlMatch.getAttribute('data-hometeam') || '';
                    const mAway = htmlMatch.getAttribute('data-awayteam') || '';
                    
                    let showMatch = true;
                    
                    if (currentGroup !== 'all' && mGroup !== currentGroup) {
                        showMatch = false;
                    }
                    
                    if (currentTeam !== '' && !mHome.toLowerCase().includes(currentTeam) && !mAway.toLowerCase().includes(currentTeam)) {
                        showMatch = false;
                    }
                    
                    if (showMatch) {
                        htmlMatch.style.display = 'block';
                        dayHasVisibleMatches = true;
                    } else {
                        htmlMatch.style.display = 'none';
                    }
                });
                
                let showDay = false;
                if (currentActiveDate === 'all' || currentActiveDate === groupDate) {
                    showDay = true;
                }
                
                if (showDay && dayHasVisibleMatches) {
                    totalVisibleMatches++;
                    htmlGroup.style.display = 'block';
                    htmlGroup.style.opacity = '1';
                    htmlGroup.style.transform = 'translateY(0) scale(1)';
                } else {
                    htmlGroup.style.opacity = '0';
                    htmlGroup.style.transform = 'translateY(20px) scale(0.98)';
                    setTimeout(() => {
                        if (htmlGroup.style.opacity === '0') {
                            htmlGroup.style.display = 'none';
                        }
                    }, 400); 
                }
            });

            const noResultsMsg = document.getElementById('no-results-message');
            if (noResultsMsg) {
                if (totalVisibleMatches === 0) {
                    noResultsMsg.classList.remove('hidden');
                    noResultsMsg.classList.add('flex');
                } else {
                    noResultsMsg.classList.add('hidden');
                    noResultsMsg.classList.remove('flex');
                }
            }
        }

        dateButtons.forEach(btn => {
            btn.addEventListener('click', (e) => {
                const targetBtn = (e.target as Element).closest('button');
                if (!targetBtn) return;
                
                if (targetBtn.id === 'btn-clear-filters') {
                    currentActiveDate = 'all';
                    currentGroup = 'all';
                    currentTeam = '';
                    if (groupSelect) (groupSelect as HTMLSelectElement).value = 'all';
                    if (teamSearch) (teamSearch as HTMLInputElement).value = '';
                    
                    dateButtons.forEach(b => b.classList.remove('active'));
                    const allDateBtns = document.querySelectorAll('.calendar-date-btn[data-target-date="all"]:not(#btn-clear-filters)');
                    allDateBtns.forEach(b => b.classList.add('active'));

                    applyFilters();
                    return;
                }
                
                const targetDate = targetBtn.getAttribute('data-target-date');
                if (!targetDate) return;

                currentActiveDate = targetDate;
                
                dateButtons.forEach(b => b.classList.remove('active'));
                
                const matchedButtons = document.querySelectorAll(`.calendar-date-btn[data-target-date="${targetDate}"]`);
                matchedButtons.forEach(b => b.classList.add('active'));

                if (targetBtn.closest('#ribbon-container')) {
                    targetBtn.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
                }

                applyFilters();
            });
        });

        if(groupSelect) {
            groupSelect.onchange = (e) => {
                currentGroup = (e.target as HTMLSelectElement).value;
                applyFilters();
            };
        }

        if(teamSearch) {
            teamSearch.oninput = (e) => {
                currentTeam = (e.target as HTMLInputElement).value.toLowerCase().trim();
                applyFilters();
            };
        }
    }

    // Initialize on first load and after view transitions
    initCalendar();
    document.addEventListener('astro:page-load', initCalendar);
</script>
