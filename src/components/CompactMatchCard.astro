---
interface Props {
  homeTeam: { name: string; flag: string };
  awayTeam: { name: string; flag: string };
  score: { home: number; away: number };
  penalties?: { home: number; away: number };
}

const { homeTeam, awayTeam, score } = Astro.props;
---

<div class="flex flex-col min-w-[180px]">
  <!-- Top Row: Logo - Score - Logo -->
  <div class="flex items-center justify-center gap-4 mb-2">
    <!-- Home Logo -->
    <div class="w-10 h-10 rounded-full bg-[#2a5b7c] flex items-center justify-center text-xl shadow-lg shrink-0 overflow-hidden">
      {homeTeam.flag.endsWith('.png') ? (
        <img src={`/flags/${homeTeam.flag}`} alt={homeTeam.name} class="w-full h-full object-cover" />
      ) : (
        homeTeam.flag
      )}
    </div>
    
    <!-- Score -->
    <div class="flex items-end gap-3 font-bold">
      <span class="text-gold text-2xl leading-none">{score.home}</span>
      <span class="text-white/30 text-[0.6rem] uppercase tracking-wider mb-1">vs</span>
      <span class="text-white text-2xl leading-none">{score.away}</span>
    </div>

    <!-- Away Logo -->
    <div class="w-10 h-10 rounded-full bg-[#1e2336] flex items-center justify-center text-xl shadow-lg shrink-0 overflow-hidden">
      {awayTeam.flag.endsWith('.png') ? (
        <img src={`/flags/${awayTeam.flag}`} alt={awayTeam.name} class="w-full h-full object-cover" />
      ) : (
        awayTeam.flag
      )}
    </div>
  </div>

  <!-- Middle Row: Penalties -->
  {Astro.props.penalties && (
    <div class="flex items-center justify-center gap-2 mb-2">
      <div class="h-[1px] w-6 bg-gold/30"></div>
      <span class="text-white/40 text-[0.5rem] tracking-[1px] uppercase font-bold">Penalties ({Astro.props.penalties.home} - {Astro.props.penalties.away})</span>
      <div class="h-[1px] w-6 bg-gold/30"></div>
    </div>
  )}

  <!-- Bottom Row: Team Names -->
  <div class="flex justify-between px-2 w-full mt-1">
    <span class="text-[0.65rem] font-bold text-white uppercase tracking-wider">{homeTeam.name}</span>
    <span class="text-[0.65rem] font-bold text-white uppercase tracking-wider">{awayTeam.name}</span>
  </div>
</div>
