---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';

interface Standing {
	team: { name: string; flag: string };
	played: number;
	won: number;
	drawn: number;
	lost: number;
	gf: number;
	ga: number;
	gd: number;
	pts: number;
}

interface Props {
	standings: Standing[];
}

const { standings } = Astro.props;

const images = import.meta.glob<{ default: ImageMetadata }>('/src/assets/flags/*.{png,jpg,jpeg,svg}', { eager: true });
const resolveFlag = (flagName: string) => {
    const path = `/src/assets/flags/${flagName}`;
    return images[path] ? images[path].default : images['/src/assets/flags/unk.png'].default;
};
---

<div class="w-full overflow-x-auto bg-dark-card rounded-xl border border-white/5">
	<table class="w-full border-collapse text-sm">
		<thead>
			<tr class="bg-black/20 text-muted font-bold text-[0.75rem] uppercase tracking-widest">
				<th class="p-4">POS</th>
				<th class="p-4 text-left">EQUIPO</th>
				<th class="p-4">PJ</th>
				<th class="p-4">G</th>
				<th class="p-4">E</th>
				<th class="p-4">P</th>
				<th class="p-4 hidden sm:table-cell">GF</th>
				<th class="p-4 hidden sm:table-cell">GC</th>
				<th class="p-4 hidden sm:table-cell">DG</th>
				<th class="p-4 font-black text-gold">PTS</th>
			</tr>
		</thead>
		<tbody>
			{standings.map((row, index) => (
				<tr class={`border-b border-white/5 last:border-b-0 ${index < 2 ? 'bg-gradient-to-r from-green-accent/5 to-transparent' : ''}`}>
					<td class={`text-center font-bold text-gold p-4 ${index < 2 ? 'border-l-4 border-green-accent' : ''}`}>{index + 1}</td>
					<td class="p-4 text-left">
						<div class="flex items-center gap-3">
							<div class="w-6 h-6 rounded-full overflow-hidden border border-white/20 shrink-0 shadow-md">
								<Image src={resolveFlag(row.team.flag) as ImageMetadata} alt="" class="w-full h-full object-cover rounded-full" />
							</div>
							<span class="font-bold text-white tracking-wide truncate">{row.team.name}</span>
						</div>
					</td>
					<td class="text-center p-4">{row.played}</td>
					<td class="text-center p-4">{row.won}</td>
					<td class="text-center p-4">{row.drawn}</td>
					<td class="text-center p-4">{row.lost}</td>
					<td class="text-center p-4 hidden sm:table-cell">{row.gf}</td>
					<td class="text-center p-4 hidden sm:table-cell">{row.ga}</td>
					<td class="text-center p-4 hidden sm:table-cell">{row.gd}</td>
					<td class="text-center p-4 font-black text-gold">{row.pts}</td>
				</tr>
			))}
		</tbody>
	</table>
</div>

