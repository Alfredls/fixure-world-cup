---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';

interface Props {
  team: { name: string; flag: string };
  bgClass: string;
  nameClassName?: string;
}

const { team, bgClass, nameClassName = "" } = Astro.props;

import { resolveFlag } from '../lib/flags';
---

<div class="flex flex-col items-center group/team-inner">
  <div class={`w-16 h-16 sm:w-24 sm:h-24 md:w-64 md:h-64 rounded-full flex items-center justify-center shadow-2xl relative z-10 overflow-hidden border border-white/25 p-1 sm:p-2 md:p-4 transition-all duration-700 group-hover/team-inner:border-white/30`}>
    <div class="w-full h-full rounded-full overflow-hidden shadow-inner">
      {team.flag.endsWith('.png') ? (
        <Image src={resolveFlag(team.flag) as ImageMetadata} alt={team.name} class="w-full h-full object-cover" />
      ) : (
        <span class="text-3xl sm:text-5xl md:text-8xl">{team.flag}</span>
      )}
    </div>
  </div>
  <h2 class={`text-xs sm:text-lg md:text-5xl font-bebas text-white uppercase tracking-[2px] md:tracking-[4px] mt-2 sm:mt-4 md:mt-8 transition-all duration-500 group-hover/team-inner:text-gold group-hover/team-inner:scale-110 ${nameClassName}`}>
    {team.name}
  </h2>
</div>
