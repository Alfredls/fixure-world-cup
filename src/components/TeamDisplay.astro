---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';

interface Props {
  team: { name: string; flag: string };
  bgClass: string;
  nameClassName?: string;
}

const { team, bgClass, nameClassName = "" } = Astro.props;

const images = import.meta.glob<{ default: ImageMetadata }>('/src/assets/flags/*.{png,jpg,jpeg,svg}', { eager: true });
const resolveFlag = (flagName: string) => {
    const path = `/src/assets/flags/${flagName}`;
    return images[path] ? images[path].default : images['/src/assets/flags/unk.png'].default;
};
---

<div class="flex flex-col items-center">
  <div class={`w-24 h-24 md:w-56 md:h-56 rounded-full ${bgClass} flex items-center justify-center shadow-2xl relative z-10 overflow-hidden`}>
    {team.flag.endsWith('.png') ? (
      <Image src={resolveFlag(team.flag)} alt={team.name} class="w-full h-full object-cover" />
    ) : (
      <span class="text-6xl md:text-8xl">{team.flag}</span>
    )}
  </div>
  <h2 class={`text-2xl md:text-4xl font-bold text-white uppercase tracking-tight flex-1 flex text-center mt-6 ${nameClassName}`}>
    {team.name}
  </h2>
</div>
